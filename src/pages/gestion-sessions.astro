---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Gestion sessions, frais &amp; promotions — Direction" role="dir" page="gestion">
<style is:global>

  body { background: var(--surface-canvas); }

  .tabs { display: flex; gap: var(--space-2); border-bottom: 1px solid var(--border-subtle); margin-bottom: var(--space-7); }
  .tab { background: transparent; border: none; border-bottom: 2px solid transparent; font-family: inherit; padding: var(--space-4) var(--space-5); font-size: var(--text-sm); font-weight: 500; color: var(--text-secondary); cursor: pointer; margin-bottom: -1px; display: inline-flex; align-items: center; gap: var(--space-3); }
  .tab:hover { color: var(--text-primary); }
  .tab.is-active { color: var(--ink-900); font-weight: 600; border-bottom-color: var(--ink-800); }
  .panel { display: none; }
  .panel.is-active { display: block; }

  .card + .card { margin-top: var(--space-5); }

  /* Sessions */
  .sess-row { display: flex; align-items: center; gap: var(--space-6); padding: var(--space-6) var(--space-7); border-top: 1px solid var(--border-subtle); }
  .sess-row:first-child { border-top: 0; }
  .sess-ic { width: 44px; height: 44px; border-radius: var(--radius-sm); background: var(--ink-50); color: var(--ink-700); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .sess-main { flex: 1; min-width: 0; }
  .sess-nm { font-size: var(--text-base); font-weight: 600; }
  .sess-meta { font-size: var(--text-xs); color: var(--text-tertiary); margin-top: var(--space-2); display: flex; gap: var(--space-2) var(--space-5); flex-wrap: wrap; }
  .sess-meta span { display: inline-flex; align-items: center; gap: var(--space-2); }
  .sess-meta svg { color: var(--text-tertiary); }
  .sess-fill { width: 200px; flex-shrink: 0; }
  /* R-03 : reformater (pleine largeur sous le texte) plutôt que masquer la capacité */
  @media (max-width: 820px){ .sess-row { flex-wrap: wrap; } .sess-fill { width: 100%; box-sizing: border-box; padding-left: calc(44px + var(--space-6)); } }
  .sess-fill-top { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: var(--space-3); font-size: var(--text-xs); }
  .sess-fill-top .pl { color: var(--text-tertiary); } .sess-fill-top b { color: var(--text-primary); font-variant-numeric: tabular-nums; }
  .sess-track { background: var(--sand-100); height: 8px; border-radius: 999px; overflow: hidden; }
  .sess-bar { height: 100%; border-radius: 999px; background: linear-gradient(90deg, var(--ink-700), var(--ink-800)); }
  .sess-side { display: flex; flex-direction: column; align-items: flex-end; gap: var(--space-3); flex-shrink: 0; }
  .sess-row.closed { opacity: 0.66; }

  /* Frais table */
  .fees th, .fees td { padding: var(--space-5) var(--space-7); }
  .fee-amt { font-family: var(--font-display); font-weight: 700; color: var(--text-primary); font-variant-numeric: tabular-nums; }
  .fee-amt .cur { font-size: var(--text-xs); color: var(--text-tertiary); font-weight: 600; margin-left: 3px; }
  .fee-na { color: var(--text-tertiary); font-style: italic; font-size: var(--text-sm); }

  /* Promotions */
  .promo-row { display: flex; align-items: center; gap: var(--space-5); padding: var(--space-6) var(--space-7); border-top: 1px solid var(--border-subtle); }
  .promo-row:first-child { border-top: 0; }
  .promo-rate { width: 56px; height: 56px; border-radius: var(--radius-md); background: var(--accent-50); color: var(--accent-700); display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-size: var(--text-lg); font-weight: 700; flex-shrink: 0; }
  .promo-main { flex: 1; min-width: 0; }
  .promo-nm { font-size: var(--text-base); font-weight: 600; }
  .promo-meta { font-size: var(--text-xs); color: var(--text-tertiary); margin-top: 2px; }
  .promo-row.off { opacity: 0.6; }
  .promo-row.off .promo-rate { background: var(--sand-100); color: var(--sand-500); }

</style>


<!-- Barre supérieure -->
<header class="app-top">
  <div class="app-top-inner">
    <div class="brand"><img src="/lanem-logo.webp" alt="LaNEM" style="height:36px;width:auto;display:block"></div>
    <nav class="nav">
      <a data-roles="dir" href="/tableau-direction"><svg class="ico-sm"><use href="#i-chart"/></svg>Tableau de bord</a>
      <a href="/liste-dossiers"><svg class="ico-sm"><use href="#i-folders"/></svg>Dossiers</a>
      <a data-roles="dir" href="/gestion-sessions" class="is-active"><svg class="ico-sm"><use href="#i-coins"/></svg>Sessions &amp; frais</a>
      <a data-roles="sm" href="/personnel">Personnel</a>
      <a data-roles="sm" href="/exploitation">Exploitation</a>
      <a data-roles="sm" href="/reglages">Réglages</a>
    </nav>
    <div class="app-user">
      <div class="meta"><div class="nm">Pr. Adjovi Mensah</div><div class="rl">Direction</div></div>
      <div class="av">AM</div>
    </div>
  </div>
</header>

<main class="page">
  <div class="page-head">
    <div>
      <h1 class="page-title">Sessions, frais &amp; promotions</h1>
      <p class="page-sub"><b>Lecture seule.</b> Les sessions s'administrent dans le Desk Frappe ; la grille des frais et les promotions appartiennent à UF (source de vérité, répliquées ici par synchronisation quotidienne).</p>
    </div>
  </div>

  <div class="tabs" id="tabs" role="tablist" aria-label="Sessions, frais et promotions">
    <button type="button" class="tab is-active" role="tab" aria-selected="true" data-tab="sessions"><svg class="ico-sm"><use href="#i-cal"/></svg>Sessions</button>
    <button type="button" class="tab" role="tab" aria-selected="false" data-tab="frais"><svg class="ico-sm"><use href="#i-coins"/></svg>Grille des frais</button>
    <button type="button" class="tab" role="tab" aria-selected="false" data-tab="promos"><svg class="ico-sm"><use href="#i-graduation"/></svg>Promotions &amp; bourses</button>
  </div>

  <section class="panel is-active" data-panel="sessions">
    <div class="card">
      <div class="card-head"><span class="card-title">Sessions d'admission</span><span class="t-caption">Édition : Desk Frappe</span></div>
      <div id="sessions-list"><div style="display:flex;flex-direction:column;gap:8px;padding:var(--space-6)"><div class="em-skeleton em-skeleton--title"></div><div class="em-skeleton em-skeleton--text"></div><div class="em-skeleton em-skeleton--text em-skeleton--text-short"></div></div></div>
    </div>
  </section>

  <section class="panel" data-panel="frais">
    <div class="card">
      <div class="card-head"><span class="card-title">Grille des frais (réplique UF)</span><span class="t-caption">Montants en FCFA · source : UF</span></div>
      <div class="em-table-wrap" style="border:0;border-radius:0">
        <table class="em-table fees">
          <thead><tr><th>Clé</th><th>Programme</th><th>Niveau</th><th>Type</th><th>Montant</th></tr></thead>
          <tbody id="frais-rows"></tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="panel" data-panel="promos">
    <div class="card">
      <div class="card-head"><span class="card-title">Promotions actives (réplique UF)</span></div>
      <div class="em-table-wrap" style="border:0;border-radius:0">
        <table class="em-table"><thead><tr><th>Code</th><th>Nom</th><th>Taux</th><th>Période</th><th>Programme</th></tr></thead><tbody id="promos-rows"></tbody></table>
      </div>
    </div>
    <div class="card">
      <div class="card-head"><span class="card-title">Catalogue des bourses (réplique UF)</span></div>
      <div class="em-table-wrap" style="border:0;border-radius:0">
        <table class="em-table"><thead><tr><th>Clé</th><th>Nom</th><th>Catégorie</th><th>Taux</th><th>Groupe d'exclusivité</th></tr></thead><tbody id="bourses-rows"></tbody></table>
      </div>
    </div>
  </section>
</main>

<script is:inline>
/* C4-FRONT — gestion-sessions en LECTURE SEULE (arbitrage architecte) :
   sessions = Desk ; frais/promos/bourses = miroirs UF (DEC-206/219 : l'écriture appartient
   à UF — aucune édition ici). Lecture via REST /api/resource (DocPerms read des rôles staff). */
(function(){
  const API = window.EmelaAPI, esc = window.EmelaUI.esc;

  const tabsEl = document.getElementById('tabs');
  function selectTab(t){
    document.querySelectorAll('.tab').forEach(x=>{ const on = x===t; x.classList.toggle('is-active', on); x.setAttribute('aria-selected', on?'true':'false'); });
    document.querySelectorAll('.panel').forEach(p=>p.classList.toggle('is-active', p.dataset.panel===t.dataset.tab));
  }
  tabsEl.addEventListener('click', e=>{ const t = e.target.closest('.tab'); if(t) selectTab(t); });
  // A-01 : navigation aux flèches entre onglets
  tabsEl.addEventListener('keydown', e=>{
    if(e.key!=='ArrowRight' && e.key!=='ArrowLeft') return;
    const tabs=[...tabsEl.querySelectorAll('.tab')];
    const i=tabs.indexOf(document.activeElement); if(i<0) return;
    const j=e.key==='ArrowRight' ? (i+1)%tabs.length : (i-1+tabs.length)%tabs.length;
    tabs[j].focus(); selectTab(tabs[j]); e.preventDefault();
  });

  window.onEmelaRole = async function(role){
    window.__emelaRole = role;  /* W4 : rôle dispo pour le rendu du bouton Clôturer */
    try {
      const [sessions, frais, promos, bourses] = await Promise.all([
        API.resource('Admission Session', ['name','label','academic_year','programme_code','programme_label','is_open','opens_on','closes_on'], null, 'opens_on desc'),
        API.resource('Admission Fee Catalog', ['name','program_code','level_code','fee_type','amount_xof'], null, 'name asc'),
        API.resource('Admission Promotion Mirror', ['mirror_key','promo_name','rate','start_date','end_date','program'], null, 'start_date desc'),
        API.resource('Admission Scholarship Mirror', ['mirror_key','scholarship_name','category','rate','exclusivity_group'], null, 'category asc'),
      ]);

      document.getElementById('sessions-list').innerHTML = (sessions||[]).map(s =>
        '<div class="sess-row'+(s.is_open?'':' closed')+'"><span class="sess-ic"><svg class="ico-lg"><use href="#i-cal"/></svg></span>'+
        '<div class="sess-main"><div class="sess-nm">'+esc(s.label||s.name)+'</div>'+
        '<div class="sess-meta"><span>'+esc(s.programme_label||s.programme_code||'')+'</span><span>'+esc(s.academic_year||'')+'</span><span>Dépôts : '+esc(API.fmtDate(s.opens_on))+' → '+esc(API.fmtDate(s.closes_on))+'</span></div></div>'+
        '<div class="sess-side"><span class="em-badge em-badge--'+(s.is_open?'success':'neutral')+' em-badge--sm"><span class="em-badge-dot"></span>'+(s.is_open?'Ouverte':'Fermée')+'</span>'+
        (s.is_open && window.__emelaRole==='dir' ? ' <button type="button" class="em-btn em-btn--secondary em-btn--sm" data-close-session="'+esc(s.name)+'" data-label="'+esc(s.label||s.name)+'">Clôturer…</button>' : '')+
        '</div></div>'
      ).join('') || '<p class="t-muted" style="padding:var(--space-6)">Aucune session.</p>';

      /* W4 (B0.3/B0.4) : clôture de session — PRÉVISUALISATION (dry-run serveur) puis
         confirmation explicite. Bascule en masse : instruits→REF, non-aboutis→DES,
         candidats notifiés ; la rétention prend ensuite le relais. */
      document.getElementById('sessions-list').addEventListener('click', async e => {
        const btn = e.target.closest('[data-close-session]'); if(!btn) return;
        const id = btn.dataset.closeSession, label = btn.dataset.label;
        try {
          const prev = (await API.closeSession(id, null, true)).data || {};
          const lines = Object.entries(prev.bascules||{}).map(([k,v])=>k+' : '+v+' dossier(s)').join('\n') || 'Aucun dossier à basculer.';
          window.EmelaUI.emModal({
            title: 'Clôturer la session — '+label,
            lead: 'PRÉVISUALISATION ('+(prev.total||0)+' dossier(s)) :\n'+lines+'\n\nIRRÉVERSIBLE : la session ferme, les instruits passent en REF (mail motivé), les non-aboutis en DES (mail neutre).',
            fields: [{name:'motif',label:'Motif notifié (vide = motif générique de clôture)',type:'text'}],
            submitLabel: 'Clôturer définitivement',
            onSubmit: async v => {
              const res = (await API.closeSession(id, v.motif||null, false)).data || {};
              window.EmelaUI.emToast('Session clôturée — '+(res.refuses||0)+' REF, '+(res.desistes||0)+' DES'+(res.echecs?(', '+res.echecs+' échec(s)'):'.'),'success');
              window.onEmelaRole();
            },
          });
        } catch(err){ window.EmelaUI.emToast('['+(err.code||'ERR')+'] '+err.message,'error'); }
      });

      document.getElementById('frais-rows').innerHTML = (frais||[]).map(f =>
        '<tr><td class="code-cell">'+esc(f.name)+'</td><td>'+esc(f.program_code)+'</td><td>'+esc(f.level_code)+'</td><td>'+esc(f.fee_type)+'</td><td><span class="fee-amt">'+esc(API.fmtXOF(f.amount_xof))+'</span></td></tr>'
      ).join('') || '<tr><td colspan="5" class="t-muted">Catalogue vide (synchronisation UF à lancer).</td></tr>';

      document.getElementById('promos-rows').innerHTML = (promos||[]).map(p =>
        '<tr><td class="code-cell">'+esc(p.mirror_key)+'</td><td>'+esc(p.promo_name)+'</td><td>'+(Math.round(p.rate*1000)/10)+' %</td><td>'+esc(API.fmtDate(p.start_date))+' → '+esc(API.fmtDate(p.end_date))+'</td><td>'+esc(p.program||'Tous')+'</td></tr>'
      ).join('') || '<tr><td colspan="5" class="t-muted">Aucune promotion répliquée.</td></tr>';

      document.getElementById('bourses-rows').innerHTML = (bourses||[]).map(b =>
        '<tr><td class="code-cell">'+esc(b.mirror_key)+'</td><td>'+esc(b.scholarship_name)+'</td><td>'+esc(b.category||'')+'</td><td>'+(Math.round(b.rate*1000)/10)+' %</td><td>'+esc(b.exclusivity_group||'—')+'</td></tr>'
      ).join('') || '<tr><td colspan="5" class="t-muted">Aucune bourse répliquée.</td></tr>';
    } catch(e){
      if(e.code!=='AUTH') window.EmelaUI.emToast(e.message,'error');
    }
  };
})();
</script>


</Layout>
