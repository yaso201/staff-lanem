---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Gestion sessions, frais &amp; promotions — Direction" role="dir" page="gestion">
<style is:global>

  body { background: var(--surface-canvas); }

  .tabs { display: flex; gap: var(--space-2); border-bottom: 1px solid var(--border-subtle); margin-bottom: var(--space-7); }
  .tab { padding: var(--space-4) var(--space-5); font-size: var(--text-sm); font-weight: 500; color: var(--text-secondary); cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -1px; display: inline-flex; align-items: center; gap: var(--space-3); }
  .tab:hover { color: var(--text-primary); }
  .tab.is-active { color: var(--ink-900); font-weight: 600; border-bottom-color: var(--ink-800); }
  .panel { display: none; }
  .panel.is-active { display: block; }

  .card { background: var(--surface-paper); border: 1px solid var(--border-default); border-radius: var(--radius-lg); overflow: hidden; }
  .card + .card { margin-top: var(--space-5); }
  .card-head { display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); padding: var(--space-5) var(--space-7); border-bottom: 1px solid var(--border-subtle); }
  .card-title { font-size: var(--text-base); font-weight: 600; }

  /* Sessions */
  .sess-row { display: flex; align-items: center; gap: var(--space-6); padding: var(--space-6) var(--space-7); border-top: 1px solid var(--border-subtle); }
  .sess-row:first-child { border-top: 0; }
  .sess-ic { width: 44px; height: 44px; border-radius: var(--radius-sm); background: var(--ink-50); color: var(--ink-700); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .sess-main { flex: 1; min-width: 0; }
  .sess-nm { font-size: var(--text-base); font-weight: 600; }
  .sess-meta { font-size: var(--text-xs); color: var(--text-tertiary); margin-top: var(--space-2); display: flex; gap: var(--space-2) var(--space-5); flex-wrap: wrap; }
  .sess-meta span { display: inline-flex; align-items: center; gap: var(--space-2); }
  .sess-meta svg { color: var(--text-tertiary); }
  .sess-fill { width: 200px; flex-shrink: 0; }
  @media (max-width: 820px){ .sess-fill { display: none; } }
  .sess-fill-top { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: var(--space-3); font-size: var(--text-xs); }
  .sess-fill-top .pl { color: var(--text-tertiary); } .sess-fill-top b { color: var(--text-primary); font-variant-numeric: tabular-nums; }
  .sess-track { background: var(--sand-100); height: 8px; border-radius: 999px; overflow: hidden; }
  .sess-bar { height: 100%; border-radius: 999px; background: linear-gradient(90deg, var(--ink-700), var(--ink-800)); }
  .sess-side { display: flex; flex-direction: column; align-items: flex-end; gap: var(--space-3); flex-shrink: 0; }
  .sess-row.closed { opacity: 0.66; }

  /* Frais table */
  .fees th, .fees td { padding: var(--space-5) var(--space-7); }
  .fee-amt { font-family: var(--font-display); font-weight: 700; color: var(--text-primary); font-variant-numeric: tabular-nums; }
  .fee-amt .cur { font-size: var(--text-xs); color: var(--text-tertiary); font-weight: 600; margin-left: 3px; }
  .fee-na { color: var(--text-tertiary); font-style: italic; font-size: var(--text-sm); }

  /* Promotions */
  .promo-row { display: flex; align-items: center; gap: var(--space-5); padding: var(--space-6) var(--space-7); border-top: 1px solid var(--border-subtle); }
  .promo-row:first-child { border-top: 0; }
  .promo-rate { width: 56px; height: 56px; border-radius: var(--radius-md); background: var(--accent-50); color: var(--accent-700); display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-size: var(--text-lg); font-weight: 700; flex-shrink: 0; }
  .promo-main { flex: 1; min-width: 0; }
  .promo-nm { font-size: var(--text-base); font-weight: 600; }
  .promo-meta { font-size: var(--text-xs); color: var(--text-tertiary); margin-top: 2px; }
  .promo-row.off { opacity: 0.6; }
  .promo-row.off .promo-rate { background: var(--sand-100); color: var(--sand-500); }

</style>


<svg style="display:none" aria-hidden="true">
  <symbol id="i-folders" viewBox="0 0 256 256"><path d="M216,72H131.31L104,44.69A15.86,15.86,0,0,0,92.69,40H40A16,16,0,0,0,24,56V200.62A15.4,15.4,0,0,0,39.38,216H216.89A15.13,15.13,0,0,0,232,200.89V88A16,16,0,0,0,216,72ZM40,56H92.69l16,16H40Z"/></symbol>
  <symbol id="i-chart" viewBox="0 0 256 256"><path d="M232,208a8,8,0,0,1-8,8H32a8,8,0,0,1-8-8V48a8,8,0,0,1,16,0V152.69l50.34-50.35a8,8,0,0,1,11.32,0L128,132.69,180.69,80H160a8,8,0,0,1,0-16h40a8,8,0,0,1,8,8v40a8,8,0,0,1-16,0V91.31l-58.34,58.35a8,8,0,0,1-11.32,0L96,119.31l-56,56V200H224A8,8,0,0,1,232,208Z"/></symbol>
  <symbol id="i-coins" viewBox="0 0 256 256"><path d="M184,89.57V84c0-25.08-37.83-44-88-44S8,58.92,8,84v40c0,20.89,26.25,37.49,64,42.46V172c0,25.08,37.83,44,88,44s88-18.92,88-44V132C248,111.3,222.58,94.68,184,89.57Z"/></symbol>
  <symbol id="i-cal" viewBox="0 0 256 256"><path d="M208,32H184V24a8,8,0,0,0-16,0v8H88V24a8,8,0,0,0-16,0v8H48A16,16,0,0,0,32,48V208a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V48A16,16,0,0,0,208,32Zm0,176H48V96H208Z"/></symbol>
