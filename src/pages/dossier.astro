---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Vue dossier — Front management" shared={true}>
<style is:global>

  body { background: var(--surface-canvas); }
  .ico { width: 18px; height: 18px; flex-shrink: 0; }
  .ico-sm { width: 15px; height: 15px; flex-shrink: 0; }
  .ico-lg { width: 22px; height: 22px; flex-shrink: 0; }
  [hidden] { display: none !important; }

  /* ---------- Topbar produit ---------- */
  .top { background: var(--surface-paper); border-bottom: 1px solid var(--border-default); position: sticky; top: 0; z-index: var(--z-sticky); }
  .top-inner { max-width: 1240px; margin: 0 auto; padding: var(--space-4) var(--space-9); display: flex; align-items: center; justify-content: space-between; gap: var(--space-5); }
  .brand { font-family: var(--font-display); font-size: 20px; font-weight: 700; letter-spacing: -0.02em; color: var(--ink-900); }
  .brand span { color: var(--accent-500); }
  .top-right { display: flex; align-items: center; gap: var(--space-5); }
  .you { display: flex; align-items: center; gap: var(--space-3); font-size: var(--text-sm); }
  .you .nm { font-weight: 600; color: var(--text-primary); }
  .you .rl { color: var(--text-tertiary); font-size: var(--text-xs); }
  .you .av { width: 34px; height: 34px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 12px; }

  .wrap { max-width: 1240px; margin: 0 auto; padding: var(--space-6) var(--space-9) var(--space-12); }
  @media (max-width: 720px){ .top-inner, .wrap { padding-left: var(--space-5); padding-right: var(--space-5); } }

  .crumb { display: flex; align-items: center; gap: var(--space-3); font-size: var(--text-sm); color: var(--text-tertiary); margin-bottom: var(--space-5); }
  .crumb a { color: var(--text-tertiary); }
  .crumb a:hover { color: var(--text-primary); }
  .crumb svg { color: var(--sand-300); width: 14px; height: 14px; }

  /* ---------- En-tête dossier ---------- */
  .dossier-head { background: var(--surface-paper); border: 1px solid var(--border-default); border-radius: var(--radius-lg); padding: var(--space-7) var(--space-8); margin-bottom: var(--space-6); }
  .dh-top { display: flex; align-items: flex-start; justify-content: space-between; gap: var(--space-6); flex-wrap: wrap; }
  .dh-id { display: flex; gap: var(--space-5); align-items: center; }
  .dh-av { width: 56px; height: 56px; border-radius: 50%; background: var(--ink-100); color: var(--ink-800); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 19px; flex-shrink: 0; }
  .dh-name { font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 700; letter-spacing: -0.02em; line-height: 1.1; }
  .dh-sub { margin-top: var(--space-3); display: flex; flex-wrap: wrap; gap: var(--space-2) var(--space-5); font-size: var(--text-sm); color: var(--text-secondary); }
  .dh-sub span { display: inline-flex; align-items: center; gap: var(--space-2); }
  .dh-sub svg { color: var(--text-tertiary); }
  .dh-sub .code { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-tertiary); background: var(--sand-50); border: 1px solid var(--border-subtle); padding: 2px 7px; border-radius: var(--radius-xs); }
  .dh-status { display: flex; flex-direction: column; align-items: flex-end; gap: var(--space-3); }

  /* Pipeline workflow */
  .flow { display: flex; align-items: flex-start; margin-top: var(--space-8); padding-top: var(--space-7); border-top: 1px solid var(--border-subtle); }
  /* R-03 : pipeline défilable plutôt que tassé sur mobile */
  @media (max-width: 560px){ .flow { overflow-x: auto; -webkit-overflow-scrolling: touch; padding-bottom: var(--space-3); } .flow-node { flex: 0 0 auto; min-width: 68px; } }
  .flow-node { flex: 1; display: flex; flex-direction: column; align-items: center; gap: var(--space-3); position: relative; text-align: center; }
  .flow-node:not(:last-child)::after { content: ''; position: absolute; top: 13px; left: 50%; right: -50%; height: 2px; background: var(--sand-200); z-index: 0; }
  .flow-node.is-done:not(:last-child)::after { background: var(--success-500); }
  .flow-node.is-current:not(:last-child)::after { background: linear-gradient(90deg, var(--ink-800), var(--sand-200)); }
  .flow-dot { width: 28px; height: 28px; border-radius: 50%; background: var(--surface-paper); border: 2px solid var(--sand-300); color: var(--sand-500); display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; z-index: 1; }
  .flow-node.is-done .flow-dot { background: var(--success-500); border-color: var(--success-500); color: #fff; }
  .flow-node.is-current .flow-dot { background: var(--ink-800); border-color: var(--ink-800); color: #fff; box-shadow: 0 0 0 4px rgba(45,27,105,0.14); }
  .flow-lab { font-size: var(--text-xs); font-weight: 600; color: var(--text-secondary); line-height: 1.2; }
  .flow-node.is-current .flow-lab { color: var(--ink-900); }
  .flow-code { font-family: var(--font-mono); font-size: 10px; color: var(--text-tertiary); letter-spacing: 0.05em; }
  .flow-node.is-current .flow-code { color: var(--ink-700); }

  /* ---------- Layout 2 colonnes ---------- */
  .grid { display: grid; grid-template-columns: 1fr 340px; gap: var(--space-6); align-items: start; }
  @media (max-width: 980px){ .grid { grid-template-columns: 1fr; } }

  .col-main { display: flex; flex-direction: column; gap: var(--space-6); min-width: 0; }
  .rail { position: sticky; top: calc(var(--topbar-height) + var(--space-5)); display: flex; flex-direction: column; gap: var(--space-5); }
  @media (max-width: 980px){ .rail { position: static; } }

  /* Section card */
  .sec { background: var(--surface-paper); border: 1px solid var(--border-default); border-radius: var(--radius-lg); overflow: hidden; }
  .sec-head { display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); padding: var(--space-5) var(--space-7); border-bottom: 1px solid var(--border-subtle); }
  .sec-head .h { display: flex; align-items: center; gap: var(--space-4); }
  .sec-head .hc { width: 32px; height: 32px; border-radius: var(--radius-sm); background: var(--ink-50); color: var(--ink-700); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .sec-title { font-size: var(--text-base); font-weight: 600; color: var(--text-primary); }
  .sec-body { padding: var(--space-6) var(--space-7); }

  /* Pièces */
  .doc-row { display: flex; align-items: center; gap: var(--space-4); padding: var(--space-4) 0; border-top: 1px solid var(--border-subtle); }
  .doc-row:first-child { border-top: 0; padding-top: 0; }
  .doc-row:last-child { padding-bottom: 0; }
  .doc-ic { width: 36px; height: 36px; border-radius: var(--radius-sm); background: var(--sand-100); color: var(--sand-600); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .doc-ic.ok { background: var(--success-50); color: var(--success-700); }
  .doc-ic.wait { background: var(--warning-50); color: var(--warning-700); }
  .doc-main { flex: 1; min-width: 0; }
  .doc-nm { font-size: var(--text-sm); font-weight: 600; color: var(--text-primary); }
  .doc-meta { font-size: var(--text-xs); color: var(--text-tertiary); margin-top: 1px; }
  .doc-act { flex-shrink: 0; }

  /* Paiement */
  .pay-row { display: grid; grid-template-columns: 1fr auto; gap: var(--space-3) var(--space-5); align-items: center; padding: var(--space-5) 0; border-top: 1px solid var(--border-subtle); }
  .pay-row:first-child { border-top: 0; padding-top: 0; }
  .pay-row:last-child { padding-bottom: 0; }
  .pay-name { font-size: var(--text-sm); font-weight: 600; color: var(--text-primary); }
  .pay-meta { font-size: var(--text-xs); color: var(--text-tertiary); margin-top: 2px; display: flex; gap: var(--space-4); flex-wrap: wrap; }
  .pay-amt { font-family: var(--font-display); font-size: var(--text-md); font-weight: 700; color: var(--text-primary); font-variant-numeric: tabular-nums; white-space: nowrap; }
  .pay-amt .cur { font-size: var(--text-xs); color: var(--text-tertiary); font-weight: 600; margin-left: 3px; }
  .pay-side { display: flex; flex-direction: column; align-items: flex-end; gap: var(--space-3); }

  /* Notes concours */
  .notes-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-5); }
  @media (max-width: 520px){ .notes-grid { grid-template-columns: 1fr; } }
  .note-stat { background: var(--sand-25); border: 1px solid var(--border-subtle); border-radius: var(--radius-md); padding: var(--space-5) var(--space-6); }
  .note-stat .l { font-size: var(--text-2xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-tertiary); }
  .note-stat .v { font-family: var(--font-display); font-size: 28px; font-weight: 700; letter-spacing: -0.02em; color: var(--ink-900); line-height: 1; margin-top: var(--space-3); font-variant-numeric: tabular-nums; }
  .note-stat .v small { font-size: var(--text-sm); color: var(--text-tertiary); font-weight: 600; }

  /* Bourse */
  .bourse-card { display: flex; align-items: center; gap: var(--space-5); }
  .bourse-ic { width: 44px; height: 44px; border-radius: var(--radius-sm); background: var(--accent-50); color: var(--accent-700); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .bourse-main { flex: 1; }
  .bourse-nm { font-size: var(--text-base); font-weight: 600; }
  .bourse-meta { font-size: var(--text-xs); color: var(--text-tertiary); margin-top: 2px; }

  /* Historique */
  .timeline { display: flex; flex-direction: column; }
  .tl-item { display: grid; grid-template-columns: 22px 1fr; gap: var(--space-4); padding-bottom: var(--space-6); position: relative; }
  .tl-item:last-child { padding-bottom: 0; }
  .tl-rail { display: flex; flex-direction: column; align-items: center; }
  .tl-node { width: 12px; height: 12px; border-radius: 50%; background: var(--ink-200); border: 2px solid var(--surface-paper); box-shadow: 0 0 0 1px var(--border-strong); flex-shrink: 0; margin-top: 3px; }
  .tl-item.is-head .tl-node { background: var(--ink-800); box-shadow: 0 0 0 1px var(--ink-800); }
  .tl-line { width: 2px; flex: 1; background: var(--border-default); margin-top: 3px; }
  .tl-item:last-child .tl-line { display: none; }
  .tl-text { font-size: var(--text-sm); color: var(--text-primary); }
  .tl-text b { font-weight: 600; }
  .tl-meta { font-size: var(--text-xs); color: var(--text-tertiary); margin-top: 2px; display: flex; gap: var(--space-3); flex-wrap: wrap; }
  .tl-actor { font-weight: 600; }
  .tl-actor.admin { color: var(--role-admin-strong); }
  .tl-actor.resp { color: var(--accent-700); }
  .tl-actor.dir { color: var(--success-700); }

  /* ---------- Rail : résumé ---------- */
  .summary { background: var(--surface-paper); border: 1px solid var(--border-default); border-radius: var(--radius-lg); padding: var(--space-6) var(--space-6); }
  .sum-row { display: flex; justify-content: space-between; align-items: baseline; gap: var(--space-4); padding: var(--space-4) 0; border-top: 1px solid var(--border-subtle); font-size: var(--text-sm); }
  .sum-row:first-of-type { border-top: 0; padding-top: 0; }
  .sum-k { color: var(--text-tertiary); }
  .sum-v { font-weight: 600; color: var(--text-primary); text-align: right; }

  /* ---------- Rail : panneau d'actions ---------- */
  .actions { background: var(--surface-paper); border: 1px solid var(--border-default); border-radius: var(--radius-lg); overflow: hidden; }
  .act-head { padding: var(--space-5) var(--space-6); border-bottom: 1px solid var(--border-subtle); display: flex; align-items: center; gap: var(--space-3); }
  .act-head .role-dot { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; }
  .act-head .t { font-size: var(--text-sm); font-weight: 700; color: var(--text-primary); }
  .act-head .who { font-size: var(--text-xs); color: var(--text-tertiary); margin-left: auto; }
  .act-body { padding: var(--space-6); display: flex; flex-direction: column; gap: var(--space-4); }
  .act-lead { font-size: var(--text-xs); color: var(--text-secondary); line-height: var(--leading-normal); margin-bottom: var(--space-2); }
  .act-btn { width: 100%; justify-content: flex-start; gap: var(--space-3); text-align: left; }
  .act-btn .badge-mini { margin-left: auto; }
  .act-note { display: flex; gap: var(--space-3); align-items: flex-start; padding: var(--space-4) var(--space-5); background: var(--ink-50); border-radius: var(--radius-sm); font-size: var(--text-xs); color: var(--ink-900); line-height: var(--leading-normal); }
  .act-note svg { color: var(--ink-600); flex-shrink: 0; margin-top: 1px; }
  .act-decide { display: flex; gap: var(--space-3); flex-wrap: wrap; }
  .act-decide .em-btn { flex: 1 1 auto; min-width: 0; }
  .role-admin .role-dot { background: var(--role-admin); }
  .role-resp  .role-dot { background: var(--accent-500); }
  .role-dir   .role-dot { background: var(--role-direction); }
  .badge-mini { font-size: var(--text-2xs); font-weight: 700; padding: 2px 7px; border-radius: 999px; }
  .badge-mini.warn { background: var(--warning-100); color: var(--warning-700); }
  .badge-mini.info { background: var(--ink-100); color: var(--ink-800); }

  /* ---------- Scénario conditionnel (ACO) ---------- */
  .flow-node.is-aco:not(:last-child)::after { background: var(--accent-500); }
  .flow-node.is-aco .flow-dot { background: var(--accent-500); border-color: var(--accent-500); color: #fff; }
  .flow-node.is-cond:not(:last-child)::after { background: linear-gradient(90deg, var(--accent-500), var(--sand-200)); }
  .flow-node.is-cond .flow-dot { background: var(--surface-paper); border: 2px dashed var(--accent-500); color: var(--accent-700); box-shadow: 0 0 0 4px rgba(245,158,11,0.14); }
  .flow-node.is-cond .flow-lab { color: var(--accent-700); }
  .flow-node.is-cond .flow-code { color: var(--accent-700); }

  .aco-banner { display: flex; gap: var(--space-4); align-items: flex-start; padding: var(--space-5) var(--space-6); background: var(--accent-50); border: 1px solid var(--accent-200); border-radius: var(--radius-lg); }
  .aco-banner > svg { color: var(--accent-700); flex-shrink: 0; margin-top: 1px; }
  .aco-banner .t { font-size: var(--text-sm); font-weight: 700; color: var(--accent-900); }
  .aco-banner .d { font-size: var(--text-xs); color: var(--accent-900); opacity: 0.85; margin-top: 2px; line-height: var(--leading-normal); }
  .sec.levee { border-color: var(--accent-200); }
  .sec.levee .sec-head { border-bottom-color: var(--accent-200); background: var(--accent-50); }
  .sec.levee .hc { background: var(--accent-100); color: var(--accent-700); }
  .act-note.cond { background: var(--accent-50); color: var(--accent-900); }
  .act-note.cond svg { color: var(--accent-700); }

</style>
<!-- Topbar produit -->
<header class="top">
  <div class="top-inner">
    <div class="brand"><img src="/lanem-logo.webp" alt="LaNEM" style="height:36px;width:auto;display:block"></div>
    <div class="top-right">
      <div class="you app-user">
        <div style="text-align:right">
          <div class="nm">—</div>
          <div class="rl">—</div>
        </div>
        <div class="av" style="background:var(--ink-100);color:var(--ink-800)">·</div>
      </div>
    </div>
  </div>
</header>

<main class="wrap">
  <nav class="crumb">
    <a href="/liste-dossiers">Dossiers</a>
    <svg><use href="#i-caretright"/></svg>
    <span id="crumb-code" style="font-family:var(--font-mono)">…</span>
  </nav>

  <!-- En-tête dossier (rendu serveur : get_dossier) -->
  <section class="dossier-head">
    <div class="dh-top">
      <div class="dh-id">
        <div class="dh-av" id="dh-av">·</div>
        <div>
          <div class="dh-name" id="dh-name">Chargement…</div>
          <div class="dh-sub" id="dh-sub"></div>
        </div>
      </div>
      <div class="dh-status">
        <span class="st st--lg" id="dh-state"><span class="st-dot"></span>…</span>
        <span style="font-size:var(--text-xs);color:var(--text-tertiary)" id="dh-statemeta"></span>
      </div>
    </div>
    <div class="flow" id="flow"></div>
  </section>

  <div class="grid">
    <div class="col-main">
      <div class="aco-banner" id="aco-banner" hidden>
        <svg class="ico-lg"><use href="#i-hourglass"/></svg>
        <div>
          <div class="t">Admission conditionnelle — sous réserve d'obtention du Bac</div>
          <div class="d">La décision ne devient définitive (ACC) qu'après vérification du diplôme par l'Administratif puis levée par la Direction. Aucune levée automatique (INV-HUMAN).</div>
        </div>
      </div>

      <section class="sec" id="sec-pieces">
        <div class="sec-head">
          <div class="h"><span class="hc"><svg class="ico"><use href="#i-file"/></svg></span><span class="sec-title">Pièces justificatives</span></div>
          <span class="em-badge em-badge--neutral em-badge--sm" id="pieces-badge"></span>
        </div>
        <div class="sec-body" id="pieces-body"></div>
      </section>

      <section class="sec" id="sec-pay">
        <div class="sec-head">
          <div class="h"><span class="hc"><svg class="ico"><use href="#i-wallet"/></svg></span><span class="sec-title">Paiements</span></div>
          <span class="em-badge em-badge--neutral em-badge--sm" id="pay-badge"></span>
        </div>
        <div class="sec-body" id="pay-body"></div>
      </section>

      <section class="sec" id="sec-notes" hidden>
        <div class="sec-head">
          <div class="h"><span class="hc"><svg class="ico"><use href="#i-medal"/></svg></span><span class="sec-title">Notes de concours</span></div>
          <span class="em-badge em-badge--info em-badge--sm" id="notes-badge"></span>
        </div>
        <div class="sec-body" id="notes-body"></div>
      </section>

      <section class="sec" id="sec-bourses" hidden>
        <div class="sec-head">
          <div class="h"><span class="hc"><svg class="ico"><use href="#i-coins"/></svg></span><span class="sec-title">Bourses</span></div>
          <span class="em-badge em-badge--accent em-badge--sm" id="bourses-badge"></span>
        </div>
        <div class="sec-body" id="bourses-body"></div>
      </section>

      <section class="sec">
        <div class="sec-head">
          <div class="h"><span class="hc"><svg class="ico"><use href="#i-clock"/></svg></span><span class="sec-title">Historique du dossier</span></div>
        </div>
        <div class="sec-body"><div class="timeline" id="timeline"></div></div>
      </section>

      <section class="sec" id="sec-sm" data-roles="sm" hidden>
        <div class="sec-head">
          <div class="h"><span class="hc"><svg class="ico"><use href="#i-shield"/></svg></span><span class="sec-title">Administration (super-admin)</span></div>
          <span class="em-badge em-badge--neutral em-badge--sm">SM</span>
        </div>
        <div class="sec-body">
          <p class="t-muted" style="margin-bottom:var(--space-4)">Gestes de support — tracés (motif obligatoire). Le lien de reprise est envoyé au candidat, jamais affiché ici.</p>
          <div style="display:flex;gap:var(--space-3);flex-wrap:wrap">
            <button type="button" class="em-btn em-btn--secondary em-btn--sm" id="sm-throttle">Débloquer (rate-limit)</button>
            <button type="button" class="em-btn em-btn--secondary em-btn--sm" id="sm-reissue">Réémettre l'accès…</button>
            <button type="button" class="em-btn em-btn--secondary em-btn--sm" id="sm-rectify">Rectifier l'identité…</button>
          </div>
        </div>
      </section>
    </div>

    <aside class="rail">
      <div class="summary" id="summary"></div>
      <div class="actions" id="actions">
        <div class="act-head" id="act-head">
          <span class="role-dot"></span>
          <span class="t" id="act-title">Actions</span>
        </div>
        <div class="act-body" id="act-body"></div>
      </div>
    </aside>
  </div>
</main>

<script is:inline>
/* C4-FRONT — page dossier DATA-DRIVEN : tout vient de staff.get_dossier (plus aucun mock).
   Le panneau d'actions reflète rôle+état ; chaque action appelle l'endpoint role-gardé
   réel et REND le message serveur en cas de refus (403/409) — le front ne décide rien.
   ARGENT : montants affichés via fmtXOF, jamais calculés ici. */
(function(){
  const API = window.EmelaAPI, UI = window.EmelaUI, esc = window.EmelaUI.esc;
  const ID = new URLSearchParams(location.search).get('c');
  let D = null, ROLE = null;

  const STATUS = {
    BRO:{l:'Brouillon'}, SOP:{l:'Soumis (prov.)'}, SOU:{l:'Soumis'},
    INC:{l:'Incomplet'}, ETU:{l:'En étude'}, ATT:{l:"Liste d'attente"},
    ADM:{l:'Admis'}, ACO:{l:'Admis sous réserve'}, ACC:{l:'Accepté'},
    INS:{l:'Inscrit'}, REF:{l:'Refusé'}, DES:{l:'Désisté'}
  };
  const PIECE_LABELS = { missing:'Manquante', uploaded:'Déposée', verified:'Déposée', rejected:'Rejetée' };
  const FEE_LABELS = { application:'Frais de candidature', competition:'Frais de concours', enrollment:"Frais d'inscription (frais 2)", annual:'Scolarité annuelle' };
  const PM_LABELS = { Cash:'Espèces', Bank:'Virement bancaire', Online:'En ligne' };

  function $(id){ return document.getElementById(id); }
  function badge(el, text, kind){ el.className = 'em-badge em-badge--' + kind + ' em-badge--sm'; el.innerHTML = '<span class="em-badge-dot"></span>' + esc(text); }

  async function refresh(){
    D = await API.getDossier(ID);
    render();
  }

  function render(){
    if(!D || !ROLE) return;
    const st = STATUS[D.statut] || {l:D.statut};
    $('crumb-code').textContent = D.dossier_id;
    $('dh-av').textContent = (D.identite.nom_complet||'?').split(/\s+/).map(w=>w[0]).slice(0,2).join('').toUpperCase();
    $('dh-name').textContent = D.identite.nom_complet || D.dossier_id;
    $('dh-sub').innerHTML =
      '<span class="code">'+esc(D.dossier_id)+'</span>'+
      '<span><svg class="ico-sm"><use href="#i-graduation"/></svg><b>'+esc(D.programme.label||D.programme.code)+'</b> · '+esc(D.programme.level_code||'')+'</span>'+
      '<span><svg class="ico-sm"><use href="#i-cal"/></svg>'+esc(D.session.label||D.session.id||'')+'</span>'+
      (D.identite.email?'<span><svg class="ico-sm"><use href="#i-user"/></svg>'+esc(D.identite.email)+'</span>':'');
    const stEl = $('dh-state');
    // L6 (Option A) : système d'état unique .st--* (12 états, sémantique riche), comme la liste
    stEl.className = 'st st--lg st--' + String(D.statut || '').toLowerCase();
    stEl.innerHTML = '<span class="st-dot"></span>'+esc(st.l)+'<span class="st-code">'+esc(D.statut)+'</span>';
    $('dh-statemeta').textContent = 'Déposé le '+API.fmtDate(D.soumis_le)+(D.person_id?' · person_id '+D.person_id:'');

    renderFlow(); renderPieces(); renderPay(); renderNotes(); renderBourses(); renderTimeline(); renderSummary(); renderActions();
    $('aco-banner').hidden = D.statut !== 'ACO';
  }

  function renderFlow(){
    const steps = D.conditionnel
      ? ['SOU','ETU','ACO','ACC','INS'] : ['BRO','SOU','ETU','ADM','ACC','INS'];
    const idx = steps.indexOf(D.statut);
    $('flow').innerHTML = steps.map((s,i)=>{
      const cls = idx===-1 ? '' : i<idx ? 'is-done' : i===idx ? 'is-current' : '';
      const dot = i<idx ? '<svg style="width:13px;height:13px"><use href="#i-check"/></svg>' : (i+1);
      return '<div class="flow-node '+cls+'"><div class="flow-dot">'+dot+'</div><div class="flow-lab">'+esc((STATUS[s]||{}).l||s)+'</div><div class="flow-code">'+s+'</div></div>';
    }).join('');
    if(idx===-1){ $('flow').innerHTML = '<p class="t-body-sm t-muted" style="margin:0">Statut hors parcours nominal : '+esc((STATUS[D.statut]||{}).l||D.statut)+'.</p>'; }
  }

  function renderPieces(){
    const pieces = D.pieces||[];
    const missing = pieces.filter(p=>p.requise && p.statut==='missing').length;
    badge($('pieces-badge'), missing? missing+' manquante(s)' : 'Complètes', missing?'warning':'success');
    $('pieces-body').innerHTML = pieces.length ? pieces.map(p=>{
      const ok = p.statut==='uploaded'||p.statut==='verified';
      return '<div class="doc-row"><span class="doc-ic '+(ok?'ok':'wait')+'"><svg class="ico"><use href="#i-'+(ok?'check':'hourglass')+'"/></svg></span>'+
        '<div class="doc-main"><div class="doc-nm">'+esc(p.label||p.code)+'</div><div class="doc-meta">'+(p.requise?'Requise':'Optionnelle')+'</div></div>'+
        '<div class="doc-act"><span class="em-badge em-badge--'+(ok?'success':'warning')+' em-badge--sm">'+esc(PIECE_LABELS[p.statut]||p.statut)+'</span></div></div>';
    }).join('') : '<p class="t-body-sm t-muted" style="margin:0">Aucune pièce attendue pour ce profil.</p>';
  }

  function renderPay(){
    const fees = D.frais||[], pays = D.paiements||[];
    const pendingOffline = pays.filter(p=>p.payment_status==='Pending' && (p.payment_mode==='Cash'||p.payment_mode==='Bank'));
    badge($('pay-badge'), pendingOffline.length? pendingOffline.length+' à confirmer':'À jour', pendingOffline.length?'warning':'success');
    let html = '';
    fees.forEach(f=>{
      const fp = pays.filter(p=>p.applicant_fee===f.name);
      const conf = fp.find(p=>p.payment_status==='Confirmed'||p.payment_status==='Paid');
      const pend = fp.find(p=>p.payment_status==='Pending');
      html += '<div class="pay-row"><div><div class="pay-name">'+esc(FEE_LABELS[f.fee_type]||f.fee_type)+'</div>'+
        '<div class="pay-meta">'+(conf?'<span>'+esc(PM_LABELS[conf.payment_mode]||conf.payment_mode)+'</span><span>Réf. '+esc(conf.provider_reference||conf.name)+'</span>':(pend?'<span>'+esc(PM_LABELS[pend.payment_mode]||pend.payment_mode)+' déclaré</span>':'<span>Aucun paiement</span>'))+'</div></div>'+
        '<div class="pay-side"><div class="pay-amt">'+esc(API.fmtXOF(f.amount_xof))+'</div>';
      if(conf){
        html += '<span class="em-badge em-badge--success em-badge--sm"><span class="em-badge-dot"></span>'+(f.status==='Paid'?'Payé':'Confirmé')+'</span>'+
          '<button class="em-btn em-btn--secondary em-btn--sm" data-receipt="'+esc(conf.name)+'">Reçu PDF</button>';
      } else if(pend && (pend.payment_mode==='Cash'||pend.payment_mode==='Bank')){
        html += (ROLE==='admin'
          ? '<button class="em-btn em-btn--primary em-btn--sm" data-confirm="'+esc(pend.name)+'"><svg class="ico-sm"><use href="#i-check"/></svg>Confirmer</button>'
          : '<span class="em-badge em-badge--warning em-badge--sm"><span class="em-badge-dot"></span>En attente</span>');
      } else if(pend){
        html += '<span class="em-badge em-badge--warning em-badge--sm"><span class="em-badge-dot"></span>En ligne · en attente webhook</span>';
      } else if(ROLE==='admin'){
        html += '<button class="em-btn em-btn--secondary em-btn--sm" data-online="'+esc(f.fee_type)+'"><svg class="ico-sm"><use href="#i-wallet"/></svg>Initier en ligne</button>';
      }
      html += '</div></div>';
    });
    if(D.acompte_xof) html += '<div class="pay-row"><div><div class="pay-name">Acompte de scolarité</div><div class="pay-meta"><span>Encaissé avec le frais 2 · transmis à UF</span></div></div><div class="pay-side"><div class="pay-amt">'+esc(API.fmtXOF(D.acompte_xof))+'</div></div></div>';
    $('pay-body').innerHTML = html || '<p class="t-body-sm t-muted" style="margin:0">Aucun frais émis.</p>';

    $('pay-body').querySelectorAll('[data-receipt]').forEach(b=> b.addEventListener('click', ()=>{
      API.downloadReceipt(b.dataset.receipt).catch(e=>UI.emToast(e.message,'error'));
    }));
    $('pay-body').querySelectorAll('[data-confirm]').forEach(b=> b.addEventListener('click', ()=> confirmPaymentModal(b.dataset.confirm)));
    $('pay-body').querySelectorAll('[data-online]').forEach(b=> b.addEventListener('click', ()=> onlineModal(b.dataset.online)));
  }

  function confirmPaymentModal(paymentId){
    // ARGENT — confirmation offline : canal + justificatif OBLIGATOIRE (PAY-CONFIRM-AGENT)
    UI.emModal({
      title: 'Confirmer le paiement',
      lead: "Confirme l'encaissement espèces/banque. Le justificatif est obligatoire et immuable après confirmation.",
      fields: [
        { name:'mode', label:'Canal', type:'select', options:[{value:'cash',label:'Espèces'},{value:'bank',label:'Virement bancaire'}], required:true },
        { name:'justif', label:'Justificatif (PDF/image)', type:'file', required:true, accept:'.pdf,.png,.jpg,.jpeg' },
      ],
      submitLabel: 'Confirmer le paiement',
      onSubmit: async v => {
        const url = await API.uploadJustificatif(v.justif);
        await API.confirmOfflinePayment(D.dossier_id, v.mode, url, paymentId);
        UI.emToast('Paiement confirmé. Reçu envoyé au candidat.', 'success');
        await refresh();
      },
    });
  }

  function onlineModal(feeType){
    const isF2 = feeType === 'enrollment';
    UI.emModal({
      title: 'Initier un paiement en ligne',
      lead: 'Pré-crée un paiement en ligne lié au dossier (DEC-266). Le webhook le confirmera.',
      fields: isF2 ? [{ name:'acompte', label:'Acompte de scolarité (XOF, optionnel)', type:'number', value:'0' }] : [],
      submitLabel: 'Initier',
      onSubmit: async v => {
        const d = await API.initiateOnlinePayment(D.dossier_id, feeType, Number(v.acompte||0));
        UI.emToast('Paiement initié (réf. '+(d.reference||'')+', '+API.fmtXOF(d.amount_xof)+').', 'success');
        await refresh();
      },
    });
  }

  function renderNotes(){
    $('sec-notes').hidden = !D.is_prepa;
    if(!D.is_prepa) return;
    const n = D.notes||{};
    badge($('notes-badge'), n.validees?'Validées':(n.valeurs?'Saisies · à valider':'À saisir'), n.validees?'success':(n.valeurs?'info':'warning'));
    let html = '';
    if(n.valeurs){
      html += '<div class="notes-grid" style="margin-bottom:var(--space-5)">'+Object.entries(n.valeurs).map(([k,v])=>
        '<div class="note-stat"><div class="l">'+esc(k)+'</div><div class="v">'+esc(String(v))+'</div></div>').join('')+'</div>';
    } else {
      html += '<p class="t-body-sm t-muted">Aucune note saisie pour ce dossier de concours.</p>';
    }
    $('notes-body').innerHTML = html;
  }

  function renderBourses(){
    const B = D.bourses||{};
    const has = (B.demandees||[]).length || (B.validees||[]).length;
    $('sec-bourses').hidden = !has;
    if(!has) return;
    const state = (B.validees||[]).length?'Validées':( (B.proposees||[]).length?'Proposées':'Demandées');
    badge($('bourses-badge'), state, (B.validees||[]).length?'success':'accent');
    function list(items, tag){
      if(!(items||[]).length) return '<span class="t-muted">—</span>';
      return items.map(b=>'<div class="bourse-card" style="margin-bottom:var(--space-3)"><span class="bourse-ic"><svg class="ico-lg"><use href="#i-medal"/></svg></span>'+
        '<div class="bourse-main"><div class="bourse-nm">'+esc(b.nom)+(b.taux!=null?' — '+esc(String(Math.round(b.taux*1000)/10))+' %':'')+'</div>'+
        '<div class="bourse-meta">'+tag+(b.exclusivity_group?' · groupe '+esc(b.exclusivity_group):'')+'</div></div></div>').join('');
    }
    $('bourses-body').innerHTML =
      '<p class="t-body-sm" style="margin:0 0 var(--space-3);font-weight:600">Demandées par le candidat</p>'+list(B.demandees,'Demandée au dépôt')+
      '<p class="t-body-sm" style="margin:var(--space-5) 0 var(--space-3);font-weight:600">Proposées par le Responsable</p>'+list(B.proposees,'Proposée')+
      '<p class="t-body-sm" style="margin:var(--space-5) 0 var(--space-3);font-weight:600">Validées par la Direction</p>'+list(B.validees,'Validée — transmise à UF à l\'inscription');
  }

  function renderTimeline(){
    const t = D.transitions||[];
    $('timeline').innerHTML = t.length ? t.map((x,i)=>
      '<div class="tl-item'+(i===0?' is-head':'')+'"><div class="tl-rail"><div class="tl-node"></div><div class="tl-line"></div></div>'+
      '<div><div class="tl-text"><b>'+esc(x.from_status||'—')+' → '+esc(x.to_status)+'</b>'+(x.action?' · '+esc(x.action):'')+'</div>'+
      '<div class="tl-meta"><span class="tl-actor">'+esc(x.actor||'')+'</span><span>'+esc(API.fmtDate(x.transition_at))+'</span><span>'+esc(x.source||'')+'</span></div></div></div>'
    ).join('') : '<p class="t-body-sm t-muted" style="margin:0">Aucune transition enregistrée.</p>';
  }

  function renderSummary(){
    const pieces = D.pieces||[];
    const done = pieces.filter(p=>p.statut==='uploaded'||p.statut==='verified').length;
    const rows = [
      ['Complétude', done+' / '+pieces.length+' pièces'],
      ['Statut', (STATUS[D.statut]||{}).l || D.statut],
      ['Bourse', (D.bourses.validees||[]).length?'Validée':( (D.bourses.proposees||[]).length?'Proposée':( (D.bourses.demandees||[]).length?'Demandée':'—'))],
    ];
    if(D.promo && D.promo.rate) rows.push(['Promo figée', Math.round(D.promo.rate*1000)/10+' % ('+D.promo.code+')']);
    if(D.motif_refus) rows.push(['Motif refus', D.motif_refus]);
    if(D.motif_incompletude) rows.push(['Motif incomplétude', D.motif_incompletude]);
    $('summary').innerHTML = rows.map(r=>'<div class="sum-row"><span class="sum-k">'+esc(r[0])+'</span><span class="sum-v">'+esc(r[1])+'</span></div>').join('');
  }

  /* ---------- Panneau d'actions : rôle × état (le SERVEUR re-vérifie tout) ---------- */
  function act(label, kind, fn, icon){
    const b = document.createElement('button');
    b.className = 'em-btn em-btn--'+(kind||'primary')+' act-btn';
    b.innerHTML = (icon?'<svg class="ico"><use href="#i-'+icon+'"/></svg>':'')+esc(label);
    b.addEventListener('click', fn);
    return b;
  }
  function motifModal(title, lead, submitLabel, run){
    UI.emModal({ title, lead, submitLabel, danger:true,
      fields:[{name:'motif',label:'Motif (obligatoire, communiqué au candidat)',type:'textarea',required:true}],
      onSubmit: async v => { await run(v.motif); UI.emToast('Action effectuée.','success'); await refresh(); } });
  }
  function boursesField(source, label){
    return { name:'bourses', label, type:'checkbox-list',
      options:(source||[]).map(b=>({ value:b.mirror_key, label:(b.nom||b.mirror_key)+(b.taux!=null?' — '+Math.round(b.taux*1000)/10+' %':''),
        hint:(b.exclusivity_group?'groupe '+b.exclusivity_group+' (exclusif)':'cumulable'), checked:true })) };
  }

  function renderActions(){
    const body = $('act-body');
    body.innerHTML = '';
    const head = $('act-head');
    head.classList.remove('role-admin','role-resp','role-dir');
    head.classList.add('role-'+ROLE);
    $('act-title').textContent = 'Actions — '+({admin:'Administratif',resp:'Responsable',dir:'Direction'})[ROLE];
    const S = D.statut, B = D.bourses||{};

    if(ROLE==='admin'){
      if(S==='SOU') body.appendChild(act("Mettre en étude (SOU → ETU)",'primary',async()=>{ await API.startReview(D.dossier_id); UI.emToast('Dossier mis en étude.','success'); await refresh(); },'checkcircle'));
      if(S==='SOU'||S==='ETU') body.appendChild(act('Demander un complément…','secondary',()=>motifModal('Demander un complément',"Renvoie le dossier en Incomplet (INC) — le candidat est notifié avec le motif.",'Renvoyer en incomplet',m=>API.requestComplement(D.dossier_id,m)),'paperplane'));
      if(D.is_prepa && S==='ETU' && !(D.notes&&D.notes.validees)) body.appendChild(act((D.notes&&D.notes.valeurs)?'Corriger la saisie des notes…':'Saisir les notes de concours…','primary',()=>{
        UI.emModal({ title:'Notes de concours', lead:'Saisie par l\'Administratif — la validation reste au Responsable (séparation des pouvoirs).',
          fields:[{name:'notes',label:'Notes',type:'rows',required:true,value:(D.notes&&D.notes.valeurs)||{}}], submitLabel:'Enregistrer',
          onSubmit: async v=>{ await API.saisirNotes(D.dossier_id, v.notes); UI.emToast('Notes enregistrées (à valider).','success'); await refresh(); } });
      },'pencil'));
      if(S==='ACO' && !D.bac_verified) body.appendChild(act('Vérifier le diplôme du Bac','primary',async()=>{ await API.verifyBac(D.dossier_id).catch(e=>{UI.emToast(e.message,'error');throw e;}); UI.emToast('Diplôme vérifié — la levée appartient à la Direction.','success'); await refresh(); },'graduation'));
      /* W1 (B0.1) : désistement — motif obligatoire, candidat notifié (ton neutre). */
      if(['BRO','SOP','SOU','ETU','ATT','ADM','ACO','ACC'].includes(S))
        body.appendChild(act('Désister le dossier…','secondary',()=>motifModal('Désister le dossier',
          'Clôture le dossier (DES) — geste sur demande du candidat. Le motif est obligatoire et le candidat est notifié (ton neutre, pas un refus).',
          'Désister', m=>API.withdraw(D.dossier_id,m)),'x'));
      const note = document.createElement('div');
      note.className='act-note';
      note.innerHTML='<svg class="ico"><use href="#i-info"/></svg><span>Vous préparez le dossier (pièces via complément, paiements, notes, désistement sur demande). La décision appartient au Responsable, la validation à la Direction.</span>';
      body.appendChild(note);
    }

    if(ROLE==='resp'){
      /* W5 : rang de liste d'attente OPPOSABLE — édition Resp sur dossier ATT. */
      if(S==='ATT') body.appendChild(act(D.rang_liste_attente?('Modifier le rang d\'attente (actuel : '+D.rang_liste_attente+')…'):'Fixer le rang d\'attente…','secondary',()=>{
        UI.emModal({ title:'Rang de liste d\'attente', lead:'Ordre opposable de rappel si une place se libère.',
          fields:[{name:'rang',label:'Rang (entier ≥ 1, vide pour effacer)',type:'number',value:D.rang_liste_attente||''}],
          submitLabel:'Enregistrer',
          onSubmit: async v=>{ await API.setWaitlistRank(D.dossier_id, v.rang||''); UI.emToast('Rang mis à jour.','success'); await refresh(); } });
      },'pencil'));
      if(D.is_prepa && D.notes && D.notes.valeurs && !D.notes.validees && S==='ETU')
        body.appendChild(act('Valider les notes de concours','primary',async()=>{ await API.validerNotes(D.dossier_id); UI.emToast('Notes validées.','success'); await refresh(); },'checkcircle'));
      if((S==='ETU'||S==='ATT') && (B.demandees||[]).length)
        body.appendChild(act('Proposer des bourses…','accent',()=>{
          UI.emModal({ title:'Proposer des bourses', lead:'Sous-ensemble des bourses DEMANDÉES par le candidat. L\'exclusivité est tranchée par la Direction à la validation.',
            fields:[boursesField(B.demandees,'Bourses à proposer')], submitLabel:'Proposer',
            onSubmit: async v=>{ await API.proposeScholarships(D.dossier_id, v.bourses); UI.emToast('Bourses proposées.','success'); await refresh(); } });
        },'medal'));
      if(S==='ETU'||S==='ATT'){
        const row = document.createElement('div'); row.className='act-decide';
        const adm = act('Admettre','primary',async()=>{ try{ await API.markAdmissible(D.dossier_id); UI.emToast('Dossier admis (ADM) — validation Direction attendue.','success'); await refresh(); }catch(e){ UI.emToast(e.message,'error'); } },'gavel');
        row.appendChild(adm);
        if(S==='ETU'){
          row.appendChild(act('Liste d\'attente…','secondary',()=>{
            UI.emModal({ title:'Mettre en liste d\'attente', fields:[{name:'rang',label:'Rang (optionnel)',type:'number'}], submitLabel:'Confirmer',
              onSubmit: async v=>{ await API.waitlist(D.dossier_id, v.rang||null); UI.emToast('Dossier en liste d\'attente.','success'); await refresh(); } });
          }));
          row.appendChild(act('Refuser…','secondary',()=>motifModal('Refuser le dossier','Le motif est obligatoire et notifié au candidat.','Refuser',m=>API.refuse(D.dossier_id,m)),'x'));
        }
        body.appendChild(row);
        if(S==='ETU' && D.conditionnel) body.appendChild(act('Admission conditionnelle (bac en attente)','accent',async()=>{ try{ await API.conditionalAdmission(D.dossier_id); UI.emToast('Admission conditionnelle prononcée (ACO).','success'); await refresh(); }catch(e){ UI.emToast(e.message,'error'); } },'hourglass'));
      }
    }

    if(ROLE==='dir'){
      if(S==='ADM') body.appendChild(act('Accepter l\'admission (+ bourses)…','primary',()=>{
        // R2 : la validation des bourses est ATOMIQUE avec l'acceptation (un seul geste Direction)
        const source = (B.proposees||[]).length ? B.proposees : B.demandees;
        const fields = (source||[]).length ? [boursesField(source,'Bourses validées avec l\'acceptation (décochez pour ne pas valider)')] : [];
        UI.emModal({ title:'Accepter l\'admission (ADM → ACC)',
          lead:(source||[]).length?'Les bourses cochées sont validées DANS LE MÊME geste (D11 §6.3) et notifiées au candidat avec la décision. Taux indicatifs — le montant final est calculé à l\'inscription.':'Aucune bourse demandée — acceptation simple.',
          fields, submitLabel:'Accepter',
          onSubmit: async v=>{ await API.acceptAdmission(D.dossier_id, fields.length? v.bourses : null); UI.emToast('Admission acceptée (frais 2 émis).','success'); await refresh(); } });
      },'check'));
      /* W2 (B0.2) : revenir sur une admissibilité = Direction (calé Workflow ADM→Refuse). */
      if(S==='ADM') body.appendChild(act('Refuser (ADM)…','secondary',()=>motifModal('Refuser un dossier admissible',
        'ADM → REF par la Direction. Le motif est obligatoire et notifié au candidat.',
        'Refuser', m=>API.refuse(D.dossier_id,m)),'x'));
      if(S==='ACO'){
        const row = document.createElement('div'); row.className='act-decide';
        row.appendChild(act('Lever la condition…','primary',()=>{
          const source = (B.proposees||[]).length ? B.proposees : B.demandees;
          const fields = (source||[]).length ? [boursesField(source,'Bourses validées avec la levée')] : [];
          UI.emModal({ title:'Lever la condition (ACO → ACC)',
            lead: D.bac_verified ? 'Le diplôme est vérifié — la levée rend l\'admission définitive.' : 'Le diplôme n\'est PAS encore vérifié : le serveur refusera (BAC_NOT_VERIFIED).',
            fields, submitLabel:'Lever la condition',
            onSubmit: async v=>{ await API.liftCondition(D.dossier_id, fields.length? v.bourses : null); UI.emToast('Condition levée — admission acceptée.','success'); await refresh(); } });
        },'check'));
        row.appendChild(act('Refuser (échec bac)…','secondary',()=>motifModal('Refuser (échec au bac)','ACO → REF. Motif obligatoire.','Refuser',m=>API.refuseCondition(D.dossier_id,m)),'x'));
        body.appendChild(row);
      }
      if(S==='ACC') body.appendChild(act('Inscrire (ACC → INS)…','primary',()=>{
        UI.emModal({ title:'Inscription réelle (ACC → INS)',
          lead:'Déclenche la création de l\'étudiant côté campus (irréversible). Le serveur vérifie les gates : frais 2 payé + consentement de transfert.',
          fields:[], submitLabel:'Inscrire',
          onSubmit: async ()=>{ await API.enroll(D.dossier_id); UI.emToast('Dossier inscrit — chaîne campus déclenchée.','success'); await refresh(); } });
      },'graduation'));
      const note = document.createElement('div');
      note.className='act-note';
      note.innerHTML='<svg class="ico"><use href="#i-shield"/></svg><span>Vous validez : acceptation (avec bourses, geste atomique), levée de condition, inscription. La levée exige la vérification préalable du diplôme par l\'Administratif (INV-HUMAN).</span>';
      body.appendChild(note);
    }

    if(!body.children.length){
      body.innerHTML = '<p class="act-lead" style="margin:0">Aucune action pour votre rôle dans l\'état actuel ('+esc(S)+').</p>';
    }
  }

  /* LOT B (SM) — encart support candidat. Le SERVEUR garde (Admission SM) ; ces boutons
     ne sont visibles que pour le SM (data-roles="sm"). Reissue envoie le lien AU CANDIDAT. */
  function bindSmSupport(){
    const t = $('sm-throttle'), r = $('sm-reissue'), x = $('sm-rectify');
    if(t) t.addEventListener('click', () => UI.emModal({
      title: 'Débloquer le candidat (rate-limit)',
      lead: "Purge les compteurs de limitation (OTP/lien) de ce dossier.",
      fields: [{ name:'motif', label:'Motif', type:'text', required:true }],
      submitLabel: 'Débloquer',
      onSubmit: async v => { await API.clearCandidateThrottle(ID, v.motif); UI.emToast('Compteurs purgés.','success'); },
    }));
    if(r) r.addEventListener('click', () => UI.emModal({
      title: "Réémettre l'accès",
      lead: "Génère un nouveau lien de reprise envoyé AU CANDIDAT par e-mail (l'ancien lien meurt ; OTP ré-armé). Le lien n'est jamais affiché ici.",
      fields: [{ name:'motif', label:'Motif', type:'text', required:true }],
      submitLabel: 'Réémettre',
      onSubmit: async v => { await API.reissueCandidateAccess(ID, v.motif); UI.emToast('Nouveau lien envoyé au candidat.','success'); },
    }));
    if(x) x.addEventListener('click', () => UI.emModal({
      title: "Rectifier l'identité",
      lead: "Rectification sur demande (RGPD). Laisser vide un champ pour ne pas le modifier.",
      fields: [
        { name:'first_name', label:'Prénom', type:'text', value: (D&&D.identite&&D.identite.prenom)||'' },
        { name:'last_name', label:'Nom', type:'text', value: (D&&D.identite&&D.identite.nom)||'' },
        { name:'email', label:'E-mail', type:'text', value: (D&&D.identite&&D.identite.email)||'' },
        { name:'phone', label:'Téléphone', type:'text', value: (D&&D.identite&&D.identite.tel)||'' },
        { name:'motif', label:'Motif', type:'text', required:true },
      ],
      submitLabel: 'Rectifier',
      onSubmit: async v => {
        const fields = {};
        ['first_name','last_name','email','phone'].forEach(k => { if(v[k]!==undefined && v[k]!=='') fields[k]=v[k]; });
        if(!Object.keys(fields).length) throw { code:'NOOP', message:'Aucun champ à rectifier.' };
        await API.rectifyCandidatePii(ID, fields, v.motif);
        UI.emToast('Identité rectifiée.','success'); refresh();
      },
    }));
  }
  bindSmSupport();

  window.onEmelaRole = function(role){ ROLE = role; if(D) render(); };
  if(!ID){ document.getElementById('dh-name').textContent = 'Dossier non spécifié'; return; }
  refresh().catch(e=>{ if(e.code!=='AUTH'){ $('dh-name').textContent='Erreur'; UI.emToast(e.message,'error'); } });
})();
</script>

</Layout>
