---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Cockpit Responsable admission — Front management" role="resp" page="cockpit">
<style is:global>

  body { background: var(--surface-canvas); }


  .sec-label { font-size: var(--text-2xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-tertiary); margin: 0 0 var(--space-4); display: flex; align-items: center; gap: var(--space-3); }

  /* Files de travail = tuiles cliquables */
  .queues { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-4); margin-bottom: var(--space-9); }
  @media (max-width: 980px){ .queues { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px){ .queues { grid-template-columns: 1fr; } }
  .queue { display: flex; flex-direction: column; gap: var(--space-3); padding: var(--space-6); background: var(--surface-paper); border: 1px solid var(--border-default); border-radius: var(--radius-lg); text-decoration: none; color: inherit; transition: border-color var(--duration-fast) var(--ease-out), box-shadow var(--duration-fast) var(--ease-out); position: relative; }
  .queue:hover { border-color: var(--ink-600); box-shadow: var(--shadow-sm); }
  .queue-top { display: flex; align-items: center; justify-content: space-between; }
  .queue-ic { width: 36px; height: 36px; border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; background: var(--ink-50); color: var(--ink-700); }
  .queue-ic.accent { background: var(--accent-50); color: var(--accent-700); }
  .queue-go { color: var(--sand-300); width: 18px; height: 18px; }
  .queue:hover .queue-go { color: var(--ink-600); }
  .queue-val { font-family: var(--font-display); font-size: 34px; font-weight: 700; letter-spacing: -0.02em; line-height: 1; color: var(--text-primary); font-variant-numeric: tabular-nums; }
  .queue-lab { font-size: var(--text-sm); font-weight: 600; color: var(--text-primary); }
  .queue-sub { font-size: var(--text-xs); color: var(--text-tertiary); }
  .queue.is-key { background: linear-gradient(160deg, var(--ink-900), var(--ink-800)); border: 0; color: #fff; }
  .queue.is-key .queue-ic { background: rgba(255,255,255,0.14); color: #fff; }
  .queue.is-key .queue-val, .queue.is-key .queue-lab { color: #fff; }
  .queue.is-key .queue-sub { color: rgba(255,255,255,0.7); }
  .queue.is-key .queue-go { color: rgba(255,255,255,0.6); }

  .cols { display: grid; grid-template-columns: 1.5fr 1fr; gap: var(--space-5); align-items: start; }
  @media (max-width: 920px){ .cols { grid-template-columns: 1fr; } }

  .card { background: var(--surface-paper); border: 1px solid var(--border-default); border-radius: var(--radius-lg); overflow: hidden; }
  .card-head { display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); padding: var(--space-5) var(--space-6); border-bottom: 1px solid var(--border-subtle); }
  .card-title { font-size: var(--text-base); font-weight: 600; }
  .card-link { font-size: var(--text-sm); font-weight: 600; color: var(--ink-700); text-decoration: none; display: inline-flex; align-items: center; gap: 4px; }
  .card-link:hover { color: var(--ink-900); }

  /* Priorité : lignes dossier cliquables */
  .pq-row { display: flex; align-items: center; gap: var(--space-4); padding: var(--space-4) var(--space-6); border-top: 1px solid var(--border-subtle); cursor: pointer; text-decoration: none; color: inherit; transition: background var(--duration-fast) var(--ease-out); }
  .pq-row:hover { background: var(--sand-25); }
  .pq-av { width: 34px; height: 34px; border-radius: 50%; background: var(--ink-100); color: var(--ink-800); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 12px; flex-shrink: 0; }
  .pq-main { flex: 1; min-width: 0; }
  .pq-nm { font-size: var(--text-sm); font-weight: 600; color: var(--text-primary); }
  .pq-meta { font-size: var(--text-xs); color: var(--text-tertiary); margin-top: 1px; }
  .pq-side { display: flex; align-items: center; gap: var(--space-4); flex-shrink: 0; }
  .pq-age { font-size: var(--text-xs); font-weight: 600; color: var(--text-secondary); text-align: right; white-space: nowrap; }
  .pq-age.warn { color: var(--warning-700); }
  .pq-age.danger { color: var(--error-700); }

  .qa { display: flex; flex-direction: column; gap: var(--space-3); padding: var(--space-5); }
  .qa a { display: flex; align-items: center; gap: var(--space-4); padding: var(--space-4) var(--space-5); border: 1px solid var(--border-default); border-radius: var(--radius-md); text-decoration: none; color: inherit; transition: border-color var(--duration-fast) var(--ease-out); }
  .qa a:hover { border-color: var(--ink-600); }
  .qa-ic { width: 34px; height: 34px; border-radius: var(--radius-sm); background: var(--ink-50); color: var(--ink-700); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .qa-ic.accent { background: var(--accent-50); color: var(--accent-700); }
  .qa-tx { font-size: var(--text-sm); font-weight: 600; }
  .qa-sub { font-size: var(--text-xs); color: var(--text-tertiary); margin-top: 1px; }

</style>


<!-- Barre supérieure -->
<header class="app-top">
  <div class="app-top-inner">
    <div class="brand"><img src="/lanem-logo.webp" alt="LaNEM" style="height:36px;width:auto;display:block"></div>
    <nav class="nav">
      <a data-roles="admin" href="/espace-administratif"><svg class="ico-sm"><use href="#i-tray"/></svg>Espace de traitement</a>
      <a data-roles="resp" href="/cockpit-responsable" class="is-active"><svg class="ico-sm"><use href="#i-gauge"/></svg>Cockpit</a>
      <a data-roles="dir" href="/tableau-direction"><svg class="ico-sm"><use href="#i-chart"/></svg>Tableau de bord</a>
      <a href="/liste-dossiers"><svg class="ico-sm"><use href="#i-folders"/></svg>Dossiers</a>
      <a data-roles="dir" href="/gestion-sessions"><svg class="ico-sm"><use href="#i-coins"/></svg>Sessions &amp; frais</a>
      <a data-roles="sm" href="/personnel">Personnel</a>
      <a data-roles="sm" href="/exploitation">Exploitation</a>
      <a data-roles="sm" href="/reglages">Réglages</a>
    </nav>
    <div class="app-user">
      <div class="meta"><div class="nm">Karim Sossou</div><div class="rl">Responsable admission</div></div>
      <div class="av">KS</div>
    </div>
  </div>
</header>

<main class="page">
  <div class="page-head">
    <div>
      <h1 class="page-title" id="greet">Bonjour</h1>
      <p class="page-sub" id="greet-sub">Vos files d'instruction et de décision.</p>
    </div>
  </div>

  <p class="sec-label">Mes files de travail</p>
  <div class="queues">
    <a class="queue is-key" href="/liste-dossiers?preset=enetude">
      <div class="queue-top"><span class="queue-ic"><svg class="ico"><use href="#i-hourglass"/></svg></span><svg class="queue-go"><use href="#i-caretright"/></svg></div>
      <div class="queue-val" id="q-etu">—</div>
      <div class="queue-lab">En étude</div>
      <div class="queue-sub">À instruire et décider (ETU)</div>
    </a>
    <a class="queue is-key" href="/liste-dossiers?preset=notesv">
      <div class="queue-top"><span class="queue-ic accent"><svg class="ico"><use href="#i-medal"/></svg></span><svg class="queue-go"><use href="#i-caretright"/></svg></div>
      <div class="queue-val" id="q-notesv">—</div>
      <div class="queue-lab">Notes à valider</div>
      <div class="queue-sub">Saisies par l'Administratif</div>
    </a>
    <a class="queue" href="/liste-dossiers?preset=bourse">
      <div class="queue-top"><span class="queue-ic"><svg class="ico"><use href="#i-coins"/></svg></span><svg class="queue-go"><use href="#i-caretright"/></svg></div>
      <div class="queue-val" id="q-bourse">—</div>
      <div class="queue-lab">Bourses à proposer</div>
      <div class="queue-sub">Demandes candidat à arbitrer</div>
    </a>
    <a class="queue" href="/liste-dossiers?preset=attente">
      <div class="queue-top"><span class="queue-ic"><svg class="ico"><use href="#i-hourglass"/></svg></span><svg class="queue-go"><use href="#i-caretright"/></svg></div>
      <div class="queue-val" id="q-att">—</div>
      <div class="queue-lab">Liste d'attente</div>
      <div class="queue-sub">Repêchages possibles (ATT)</div>
    </a>
  </div>

  <div class="cols">
    <div class="card">
      <div class="card-head">
        <span class="card-title">À traiter en priorité</span>
        <a class="card-link" href="/liste-dossiers?preset=enetude">Tout voir <svg class="ico-sm"><use href="#i-caretright"/></svg></a>
      </div>
      <div id="prio"></div>
    </div>
    <div>
      <div class="card">
        <div class="card-head"><span class="card-title">Accès rapides</span></div>
        <div class="qa">
          <a href="/liste-dossiers?preset=notesv"><span class="qa-ic"><svg class="ico"><use href="#i-medal"/></svg></span><div><div class="qa-tx">Valider des notes</div><div class="qa-sub">Concours Prépa</div></div></a>
          <a href="/liste-dossiers?preset=bourse"><span class="qa-ic"><svg class="ico"><use href="#i-coins"/></svg></span><div><div class="qa-tx">Proposer des bourses</div><div class="qa-sub">Demandes candidat</div></div></a>
        </div>
      </div>
    </div>
  </div>
</main>

<script is:inline>
/* C4-FRONT — cockpit Responsable branché sur staff.list_dossiers (plus de chiffres en dur). */
(function(){
  const API = window.EmelaAPI, esc = window.EmelaUI.esc;
  window.onEmelaRole = async function(role, me){
    document.getElementById('greet').textContent = 'Bonjour ' + ((me.full_name||me.user).split(' ')[0]);
    let D;
    try { D = (await API.listDossiers()).dossiers; }
    catch(e){ if(e.code!=='AUTH') window.EmelaUI.emToast(e.message,'error'); return; }
    const etu = D.filter(d=>d.statut==='ETU');
    const notesv = D.filter(d=>d.notes==='saisies');
    const bourse = D.filter(d=>d.bourse==='demandee' && (d.statut==='ETU'||d.statut==='ATT'));
    const att = D.filter(d=>d.statut==='ATT');
    document.getElementById('q-etu').textContent = etu.length;
    document.getElementById('q-notesv').textContent = notesv.length;
    document.getElementById('q-bourse').textContent = bourse.length;
    document.getElementById('q-att').textContent = att.length;
    const prio = [...notesv, ...etu].filter((d,i,a)=>a.findIndex(x=>x.dossier_id===d.dossier_id)===i).slice(0,5);
    document.getElementById('prio').innerHTML = prio.length ? prio.map(d=>{
      const init=(d.nom||'?').split(/\s+/).map(w=>w[0]).slice(0,2).join('').toUpperCase();
      const tags=[];
      if(d.notes==='saisies') tags.push('notes à valider');
      if(d.bourse==='demandee') tags.push('bourse demandée');
      return '<a class="pq-row" href="/dossier?c='+encodeURIComponent(d.dossier_id)+'"><span class="pq-av">'+esc(init)+'</span>'+
        '<div class="pq-main"><div class="pq-nm">'+esc(d.nom)+'</div><div class="pq-meta">'+esc(d.programme.label||'')+' · '+esc(d.dossier_id)+(tags.length?' · '+esc(tags.join(' · ')):'')+'</div></div>'+
        '<div class="pq-side"><span class="pq-task doc">'+esc(d.statut)+'</span></div></a>';
    }).join('') : '<p class="t-muted" style="padding:var(--space-6)">Rien à instruire pour le moment.</p>';
  };
})();
</script>


</Layout>
