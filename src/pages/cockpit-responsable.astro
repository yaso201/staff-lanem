<!-- Barre supérieure -->
<header class="app-top">
  <div class="app-top-inner">
    <div class="brand">LaNEM<span>.</span></div>
    <nav class="nav">
      <a data-roles="admin" href="/espace-administratif"><svg class="ico-sm"><use href="#i-tray"/></svg>Espace de traitement</a>
      <a data-roles="resp" href="/cockpit-responsable" class="is-active"><svg class="ico-sm"><use href="#i-gauge"/></svg>Cockpit</a>
      <a data-roles="dir" href="/tableau-direction"><svg class="ico-sm"><use href="#i-chart"/></svg>Tableau de bord</a>
      <a href="/liste-dossiers"><svg class="ico-sm"><use href="#i-folders"/></svg>Dossiers</a>
      <a data-roles="dir" href="/gestion-sessions"><svg class="ico-sm"><use href="#i-coins"/></svg>Sessions &amp; frais</a>
      <a data-roles="sm" href="/personnel">Personnel</a>
      <a data-roles="sm" href="/exploitation">Exploitation</a>
      <a data-roles="sm" href="/reglages">Réglages</a>
    </nav>
    <div class="app-user">
      <div class="meta"><div class="nm">Karim Sossou</div><div class="rl">Responsable admission</div></div>
      <div class="av">KS</div>
    </div>
  </div>
</header>

<main class="page">
  <div class="greet">
    <h1 id="greet">Bonjour</h1>
    <p id="greet-sub">Vos files d'instruction et de décision.</p>
  </div>

  <p class="sec-label">Mes files de travail</p>
  <div class="queues">
    <a class="queue is-key" href="/liste-dossiers?preset=enetude">
      <div class="queue-top"><span class="queue-ic"><svg class="ico"><use href="#i-hourglass"/></svg></span><svg class="queue-go"><use href="#i-caretright"/></svg></div>
      <div class="queue-val" id="q-etu">—</div>
      <div class="queue-lab">En étude</div>
      <div class="queue-sub">À instruire et décider (ETU)</div>
    </a>
    <a class="queue is-key" href="/liste-dossiers?preset=notesv">
      <div class="queue-top"><span class="queue-ic accent"><svg class="ico"><use href="#i-medal"/></svg></span><svg class="queue-go"><use href="#i-caretright"/></svg></div>
      <div class="queue-val" id="q-notesv">—</div>
      <div class="queue-lab">Notes à valider</div>
      <div class="queue-sub">Saisies par l'Administratif</div>
    </a>
    <a class="queue" href="/liste-dossiers?preset=bourse">
      <div class="queue-top"><span class="queue-ic"><svg class="ico"><use href="#i-coins"/></svg></span><svg class="queue-go"><use href="#i-caretright"/></svg></div>
      <div class="queue-val" id="q-bourse">—</div>
      <div class="queue-lab">Bourses à proposer</div>
      <div class="queue-sub">Demandes candidat à arbitrer</div>
    </a>
    <a class="queue" href="/liste-dossiers?preset=attente">
      <div class="queue-top"><span class="queue-ic"><svg class="ico"><use href="#i-clock"/></svg></span><svg class="queue-go"><use href="#i-caretright"/></svg></div>
      <div class="queue-val" id="q-att">—</div>
      <div class="queue-lab">Liste d'attente</div>
      <div class="queue-sub">Repêchages possibles (ATT)</div>
    </a>
  </div>

  <div class="cols">
    <div class="card">
      <div class="card-head">
        <span class="card-title">À traiter en priorité</span>
        <a class="card-link" href="/liste-dossiers?preset=enetude">Tout voir <svg class="ico-sm"><use href="#i-caretright"/></svg></a>
      </div>
      <div id="prio"></div>
    </div>
    <div>
      <div class="card">
        <div class="card-head"><span class="card-title">Accès rapides</span></div>
        <div class="qa">
          <a href="/liste-dossiers?preset=notesv"><span class="qa-ic"><svg class="ico"><use href="#i-medal"/></svg></span><div><div class="qa-tx">Valider des notes</div><div class="qa-sub">Concours Prépa</div></div></a>
          <a href="/liste-dossiers?preset=bourse"><span class="qa-ic"><svg class="ico"><use href="#i-coins"/></svg></span><div><div class="qa-tx">Proposer des bourses</div><div class="qa-sub">Demandes candidat</div></div></a>
        </div>
      </div>
    </div>
  </div>
</main>

<script is:inline>
/* C4-FRONT — cockpit Responsable branché sur staff.list_dossiers (plus de chiffres en dur). */
(function(){
  const API = window.EmelaAPI, esc = window.EmelaUI.esc;
  window.onEmelaRole = async function(role, me){
    document.getElementById('greet').textContent = 'Bonjour ' + ((me.full_name||me.user).split(' ')[0]);
    let D;
    try { D = (await API.listDossiers()).dossiers; }
    catch(e){ if(e.code!=='AUTH') window.EmelaUI.emToast('['+e.code+'] '+e.message,'error'); return; }
    const etu = D.filter(d=>d.statut==='ETU');
    const notesv = D.filter(d=>d.notes==='saisies');
    const bourse = D.filter(d=>d.bourse==='demandee' && (d.statut==='ETU'||d.statut==='ATT'));
    const att = D.filter(d=>d.statut==='ATT');
    document.getElementById('q-etu').textContent = etu.length;
    document.getElementById('q-notesv').textContent = notesv.length;
    document.getElementById('q-bourse').textContent = bourse.length;
    document.getElementById('q-att').textContent = att.length;
    const prio = [...notesv, ...etu].filter((d,i,a)=>a.findIndex(x=>x.dossier_id===d.dossier_id)===i).slice(0,5);
    document.getElementById('prio').innerHTML = prio.length ? prio.map(d=>{
      const init=(d.nom||'?').split(/\s+/).map(w=>w[0]).slice(0,2).join('').toUpperCase();
      const tags=[];
      if(d.notes==='saisies') tags.push('notes à valider');
      if(d.bourse==='demandee') tags.push('bourse demandée');
      return '<a class="pq-row" href="/dossier?c='+encodeURIComponent(d.dossier_id)+'"><span class="pq-av">'+esc(init)+'</span>'+
        '<div class="pq-main"><div class="pq-nm">'+esc(d.nom)+'</div><div class="pq-meta">'+esc(d.programme.label||'')+' · '+esc(d.dossier_id)+(tags.length?' · '+esc(tags.join(' · ')):'')+'</div></div>'+
        '<div class="pq-side"><span class="pq-task doc">'+esc(d.statut)+'</span></div></a>';
    }).join('') : '<p class="t-muted" style="padding:var(--space-6)">Rien à instruire pour le moment.</p>';
  };
})();
</script>


</Layout>
