---
import BareLayout from '../layouts/BareLayout.astro';
---
<BareLayout title="Définir votre mot de passe — LaNEM">
<style is:global>
  body { background: var(--surface-canvas); }
  .wrap { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: var(--space-9); }
  .auth-card { width: 100%; max-width: 420px; }
  .logo { display: block; height: 44px; width: auto; margin: 0 auto var(--space-7); }
  .h { font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 700; letter-spacing: -0.02em; text-align: center; color: var(--text-primary); }
  .sub { font-size: var(--text-sm); color: var(--text-secondary); text-align: center; margin-top: var(--space-3); margin-bottom: var(--space-8); }
  .field { margin-bottom: var(--space-5); }
  .field label { display: block; font-size: var(--text-sm); font-weight: 600; color: var(--text-primary); margin-bottom: var(--space-3); }
  .hint { font-size: var(--text-xs); color: var(--text-tertiary); margin-top: var(--space-3); }
  .msg { font-size: var(--text-sm); margin-top: var(--space-5); padding: var(--space-4) var(--space-5); border-radius: var(--radius-sm); display: none; }
  .msg.err { display: block; background: var(--error-50, #FEF2F2); color: var(--error-700, #B91C1C); border: 1px solid var(--error-100, #FECACA); }
  .msg.ok { display: block; background: var(--success-50, #ECFDF5); color: var(--success-700, #047857); border: 1px solid var(--success-100, #A7F3D0); }
</style>

<main class="wrap">
  <div class="em-card auth-card">
    <div class="em-card-body">
      <img class="logo" src="/lanem-logo.webp" alt="LaNEM" />
      <h1 class="h">Définir votre mot de passe</h1>
      <p class="sub">Choisissez un mot de passe pour activer votre accès LaNEM.</p>

      <form id="pw-form" autocomplete="off">
        <div class="field">
          <label for="np">Nouveau mot de passe</label>
          <input class="em-input" type="password" id="np" autocomplete="new-password" required />
          <div class="hint">Au moins 8 caractères, difficile à deviner (lettres, chiffres, symboles).</div>
        </div>
        <div class="field">
          <label for="cp">Confirmer le mot de passe</label>
          <input class="em-input" type="password" id="cp" autocomplete="new-password" required />
        </div>
        <button type="submit" class="em-btn em-btn--primary em-btn--lg em-btn--block" id="submit">Définir le mot de passe</button>
        <div class="msg" id="msg" role="alert" aria-live="assertive"></div>
      </form>
    </div>
  </div>
</main>

<script is:inline>
/* Page management de définition de mot de passe (invitation/reset).
   Appelle l'API Frappe update_password (allow_guest) avec la clé du lien — SANS credentials
   (donc en « guest » via la clé), ce qui évite le piège « connecté → ancien mot de passe ».
   La page Frappe /update-password (host API, non habillée) est ainsi contournée. */
(function () {
  var BASE = window.EMELA_API_BASE || 'http://admission-dev.localhost:8000';
  var key = new URLSearchParams(location.search).get('key') || '';
  var form = document.getElementById('pw-form');
  var msg = document.getElementById('msg');
  var btn = document.getElementById('submit');

  function show(kind, text) { msg.className = 'msg ' + kind; msg.textContent = text; }

  if (!key) { show('err', "Lien invalide : clé manquante. Demandez un nouveau lien d'invitation."); btn.disabled = true; }

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var np = document.getElementById('np').value, cp = document.getElementById('cp').value;
    if (np !== cp) { show('err', 'Les deux mots de passe ne correspondent pas.'); return; }
    if (np.length < 8) { show('err', 'Le mot de passe doit faire au moins 8 caractères.'); return; }
    btn.disabled = true; show('', ''); msg.className = 'msg';
    fetch(BASE + '/api/method/frappe.core.doctype.user.user.update_password', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
      body: JSON.stringify({ key: key, new_password: np })
    }).then(function (r) {
      return r.json().then(function (j) { return { status: r.status, body: j }; });
    }).then(function (res) {
      if (res.status === 200 && res.body && !res.body.exc) {
        show('ok', 'Mot de passe défini. Redirection vers la connexion…');
        setTimeout(function () { location.href = '/connexion'; }, 1800);
        return;
      }
      // 410 = clé invalide/expirée ; sinon message serveur (politique de complexité…)
      var m = (res.body && (res.body.message || res.body._server_messages)) || '';
      if (res.status === 410) {
        show('err', "Lien expiré ou déjà utilisé. Demandez un nouveau lien d'invitation.");
      } else if (m && /password|complex|strength|deviner|faible|policy/i.test(String(m))) {
        show('err', 'Mot de passe trop faible — choisissez-en un plus complexe (lettres, chiffres, symboles).');
      } else {
        show('err', "Impossible de définir le mot de passe. Réessayez ou demandez un nouveau lien.");
      }
      btn.disabled = false;
    }).catch(function () {
      show('err', 'Serveur injoignable. Réessayez dans un instant.');
      btn.disabled = false;
    });
  });
})();
</script>
</BareLayout>
