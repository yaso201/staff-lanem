---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Réglages & diagnostic — Super-admin" role="sm" page="reglages">
<style is:global>
  body { background: var(--surface-canvas); }
  .card { background: var(--surface-paper); border: 1px solid var(--border-default); border-radius: var(--radius-lg); overflow: hidden; }
  .card + .card { margin-top: var(--space-5); }
  .card-head { display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); padding: var(--space-5) var(--space-7); border-bottom: 1px solid var(--border-subtle); }
  .card-title { font-size: var(--text-base); font-weight: 600; }
  .diag { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-4); padding: var(--space-7); }
  @media (max-width: 640px){ .diag { grid-template-columns: 1fr; } }
  .diag-row { display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); padding: var(--space-4) var(--space-5); border: 1px solid var(--border-subtle); border-radius: var(--radius-md); }
  .diag-lbl { font-size: var(--text-sm); }
  .kv { padding: var(--space-7); }
  .kv-row { display: flex; justify-content: space-between; gap: var(--space-5); padding: var(--space-4) 0; border-top: 1px solid var(--border-subtle); font-size: var(--text-sm); }
  .kv-row:first-child { border-top: 0; }
  .kv-row b { font-variant-numeric: tabular-nums; }
</style>

<svg style="display:none" aria-hidden="true">
  <symbol id="i-folders" viewBox="0 0 256 256"><path d="M216,72H131.31L104,44.69A15.86,15.86,0,0,0,92.69,40H40A16,16,0,0,0,24,56V200.62A15.4,15.4,0,0,0,39.38,216H216.89A15.13,15.13,0,0,0,232,200.89V88A16,16,0,0,0,216,72ZM40,56H92.69l16,16H40Z"/></symbol>
  <symbol id="i-tray" viewBox="0 0 256 256"><path d="M216,40H40A16,16,0,0,0,24,56V200a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V56A16,16,0,0,0,216,40Zm0,16V152H171.31a8,8,0,0,0-5.65,2.34L139.31,180.69a8,8,0,0,1-5.65,2.34h-11.32a8,8,0,0,1-5.65-2.34L90.34,154.34A8,8,0,0,0,84.69,152H40V56Z"/></symbol>
  <symbol id="i-gauge" viewBox="0 0 256 256"><path d="M207.06,72.67A111.24,111.24,0,0,0,128,40h-.4C66.07,40.21,16,90.6,16,152.13V184a16,16,0,0,0,16,16H224a16,16,0,0,0,16-16V152C240,121.86,228,93.61,207.06,72.67Z"/></symbol>
  <symbol id="i-chart" viewBox="0 0 256 256"><path d="M232,208a8,8,0,0,1-8,8H32a8,8,0,0,1-8-8V48a8,8,0,0,1,16,0V152.69l50.34-50.35a8,8,0,0,1,11.32,0L128,132.69,180.69,80H160a8,8,0,0,1,0-16h40a8,8,0,0,1,8,8v40a8,8,0,0,1-16,0V91.31l-58.34,58.35a8,8,0,0,1-11.32,0L96,119.31l-56,56V200H224A8,8,0,0,1,232,208Z"/></symbol>
  <symbol id="i-coins" viewBox="0 0 256 256"><path d="M184,89.57V84c0-25.08-37.83-44-88-44S8,58.92,8,84v40c0,20.89,26.25,37.49,64,42.46V172c0,25.08,37.83,44,88,44s88-18.92,88-44V132C248,111.3,222.58,94.68,184,89.57Z"/></symbol>
  <symbol id="i-id" viewBox="0 0 256 256"><path d="M216,40H40A16,16,0,0,0,24,56V200a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V56A16,16,0,0,0,216,40Z"/></symbol>
  <symbol id="i-pulse" viewBox="0 0 256 256"><path d="M246.66,123.56l-32-48a8,8,0,0,0-13.32,0L176,113.58,142.66,75.56a8,8,0,0,0-13.32,0L96,113.58,62.66,75.56a8,8,0,0,0-13.32,0l-32,48A8,8,0,0,0,24,136H88a8,8,0,0,0,6.66-3.56L120,98.42l25.34,34A8,8,0,0,0,152,136h64A8,8,0,0,0,246.66,123.56Z"/></symbol>
  <symbol id="i-cog" viewBox="0 0 256 256"><path d="M128,80a48,48,0,1,0,48,48A48.05,48.05,0,0,0,128,80Zm0,80a32,32,0,1,1,32-32A32,32,0,0,1,128,160Z"/></symbol>
</svg>

<header class="app-top">
  <div class="app-top-inner">
    <div class="brand"><img src="/lanem-logo.webp" alt="LaNEM" style="height:36px;width:auto;display:block"></div>
    <nav class="nav">
      <a data-roles="admin" href="/espace-administratif"><svg class="ico-sm"><use href="#i-tray"/></svg>Espace de traitement</a>
      <a data-roles="resp" href="/cockpit-responsable"><svg class="ico-sm"><use href="#i-gauge"/></svg>Cockpit</a>
      <a data-roles="dir" href="/tableau-direction"><svg class="ico-sm"><use href="#i-chart"/></svg>Tableau de bord</a>
      <a href="/liste-dossiers"><svg class="ico-sm"><use href="#i-folders"/></svg>Dossiers</a>
      <a data-roles="dir" href="/gestion-sessions"><svg class="ico-sm"><use href="#i-coins"/></svg>Sessions &amp; frais</a>
      <a data-roles="sm" href="/personnel"><svg class="ico-sm"><use href="#i-id"/></svg>Personnel</a>
      <a data-roles="sm" href="/exploitation"><svg class="ico-sm"><use href="#i-pulse"/></svg>Exploitation</a>
      <a data-roles="sm" href="/reglages" class="is-active"><svg class="ico-sm"><use href="#i-cog"/></svg>Réglages</a>
    </nav>
    <div class="app-user">
      <div class="meta"><div class="nm">—</div><div class="rl">—</div></div>
      <div class="av">—</div>
    </div>
  </div>
</header>

<main class="page">
  <div class="page-head">
    <div>
      <h1 class="page-title">Réglages &amp; diagnostic</h1>
      <p class="page-sub"><b>Super-admin (SM).</b> Diagnostic des intégrations (présence seulement — aucun secret n'est affiché ni modifiable ici ; les secrets restent gérés par OPS) et réglages non-secrets.</p>
    </div>
  </div>

  <div class="card">
    <div class="card-head"><span class="card-title">Diagnostic des intégrations</span><button type="button" class="em-btn em-btn--secondary em-btn--sm" id="refresh">Rafraîchir</button></div>
    <div class="diag" id="diag"><p class="t-muted" style="padding:var(--space-4)">Chargement…</p></div>
  </div>

  <div class="card">
    <div class="card-head"><span class="card-title">Cloisonnement de consultation</span><button type="button" class="em-btn em-btn--secondary em-btn--sm" id="edit-cloiso">Modifier…</button></div>
    <div class="kv" id="cloiso"></div>
  </div>

  <div class="card">
    <div class="card-head"><span class="card-title">Politique de rétention (jours)</span><button type="button" class="em-btn em-btn--secondary em-btn--sm" id="edit-reten">Modifier…</button></div>
    <div class="kv" id="reten"></div>
  </div>

  <div class="card">
    <div class="card-head"><span class="card-title">Mode dégradé référentiel</span><span class="em-badge em-badge--neutral em-badge--sm" id="deg-badge">—</span></div>
    <div class="kv" id="deg"></div>
    <div style="padding:var(--space-6) var(--space-7);border-top:1px solid var(--border-subtle);display:flex;gap:var(--space-3);flex-wrap:wrap">
      <button type="button" class="em-btn em-btn--secondary em-btn--sm" id="deg-toggle">—</button>
      <button type="button" class="em-btn em-btn--secondary em-btn--sm" id="deg-edit" hidden>Ajouter / éditer un programme manuel…</button>
    </div>
    <p class="t-muted" style="padding:0 var(--space-7) var(--space-6)">Campus = source de vérité. L'édition manuelle n'est tolérée qu'en mode dégradé (campus indisponible) ; une sync campus écrase et reverrouille les lignes manuelles (vous serez alerté).</p>
  </div>
</main>

<script is:inline>
/* LOT C (SM) — réglages NON-SECRETS & diagnostic. D1 : aucun secret affiché/modifiable. */
(function(){
  const API = window.EmelaAPI, UI = window.EmelaUI, esc = UI.esc;
  function $(id){ return document.getElementById(id); }
  let SETTINGS = null;

  function badge(ok){ return '<span class="em-badge em-badge--'+(ok?'success':'error')+' em-badge--sm"><span class="em-badge-dot"></span>'+(ok?'Présent':'Absent')+'</span>'; }

  async function loadDiag(){
    try {
      const h = await API.getConfigHealth();
      const rows = [
        ['Campus (catalogue/pont)', h.campus.present],
        ['UF (frais/bourses)', h.uf.present],
        ['KkiaPay ('+esc(h.kkiapay.mode)+')', h.kkiapay.present],
        ['Secret HMAC', h.hmac_secret.present],
        ['Secret webhook', h.webhook_secret.present],
        ['SMTP (e-mails sortants)', h.smtp.present],
      ];
      let html = rows.map(r => '<div class="diag-row"><span class="diag-lbl">'+esc(r[0])+'</span>'+badge(r[1])+'</div>').join('');
      const f = h.flags || {};
      const warn = [];
      if(f.developer_mode) warn.push('developer_mode');
      if(f.expose_dev_otp) warn.push('expose_dev_otp');
      if(f.kkiapay_mock) warn.push('kkiapay_mock');
      if(warn.length) html += '<div class="diag-row" style="grid-column:1/-1;border-color:var(--accent-200)"><span class="diag-lbl">Drapeaux DEV actifs</span><span class="em-badge em-badge--warning em-badge--sm">'+esc(warn.join(', '))+'</span></div>';
      $('diag').innerHTML = html;
    } catch(e){ if(e.code!=='AUTH') UI.emToast(e.message,'error'); }
  }

  async function loadSettings(){
    try {
      SETTINGS = await API.getAdminSettings();
      const c = SETTINGS.cloisonnement;
      $('cloiso').innerHTML =
        '<div class="kv-row"><span>État</span><b>'+(c.consultation_cloisonnee?'Activé':'Désactivé')+'</b></div>'+
        '<div class="kv-row"><span>Axe</span><b>'+esc(c.consultation_axis)+'</b></div>'+
        '<div class="kv-row"><span>Périmètres (rôles)</span><b>'+esc(Object.keys(c.consultation_role_scopes||{}).join(', ')||'—')+'</b></div>';
      const r = SETTINGS.retention;
      $('reten').innerHTML = Object.entries(r).map(([k,v]) =>
        '<div class="kv-row"><span>'+esc(k)+'</span><b>'+esc(v)+'</b></div>').join('');
    } catch(e){ if(e.code!=='AUTH') UI.emToast(e.message,'error'); }
  }

  let DEG = null;
  async function loadDegraded(){
    try {
      DEG = await API.getDegradedStatus();
      const on = DEG.degraded_mode;
      const b = $('deg-badge');
      b.className = 'em-badge em-badge--'+(on?'warning':'neutral')+' em-badge--sm';
      b.innerHTML = '<span class="em-badge-dot"></span>'+(on?'Activé (édition manuelle)':'Désactivé');
      $('deg').innerHTML =
        '<div class="kv-row"><span>Lignes campus (verrouillées)</span><b>'+esc(DEG.campus_count)+'</b></div>'+
        '<div class="kv-row"><span>Lignes manuelles</span><b>'+esc(DEG.manual_count)+'</b></div>'+
        '<div class="kv-row"><span>Total programmes</span><b>'+esc(DEG.total)+'</b></div>';
      const tg = $('deg-toggle');
      tg.textContent = on ? 'Désactiver le mode dégradé' : 'Activer le mode dégradé…';
      tg.className = 'em-btn em-btn--'+(on?'secondary':'primary')+' em-btn--sm';
      $('deg-edit').hidden = !on;
    } catch(e){ if(e.code!=='AUTH') UI.emToast(e.message,'error'); }
  }

  function bind(){
    $('refresh').addEventListener('click', () => { loadDiag(); loadSettings(); loadDegraded(); });
    $('deg-toggle').addEventListener('click', () => {
      const on = DEG && DEG.degraded_mode;
      if (on) {
        API.setDegradedMode(false).then(() => { UI.emToast('Mode dégradé désactivé.','success'); loadDegraded(); })
          .catch(e => { if(e.code!=='AUTH') UI.emToast(e.message,'error'); });
      } else {
        UI.emModal({
          title: 'Activer le mode dégradé',
          lead: "À n'utiliser que si le catalogue campus est indisponible. L'édition manuelle sera écrasée à la prochaine sync campus.",
          fields: [{ name:'motif', label:'Motif', type:'text', required:true }],
          submitLabel: 'Activer',
          onSubmit: async v => { await API.setDegradedMode(true, v.motif); UI.emToast('Mode dégradé activé.','success'); loadDegraded(); },
        });
      }
    });
    $('deg-edit').addEventListener('click', () => UI.emModal({
      title: 'Programme manuel (mode dégradé)',
      lead: 'Crée ou met à jour un programme local (source = Manuel). Une ligne synchronisée depuis campus ne peut pas être modifiée ici.',
      fields: [
        { name:'programme_code', label:'Code programme', type:'text', required:true },
        { name:'title', label:'Intitulé', type:'text', required:true },
        { name:'parcours', label:'Parcours', type:'select', required:true, options:[
          {value:'Prépa',label:'Prépa'},{value:'Licence',label:'Licence'},
          {value:'Bachelor',label:'Bachelor'},{value:'Double-Diplomation',label:'Double-Diplomation'}] },
        { name:'partner_name', label:'Partenaire (optionnel)', type:'text' },
        { name:'location', label:'Lieu (optionnel)', type:'text' },
      ],
      submitLabel: 'Enregistrer',
      onSubmit: async v => {
        await API.upsertManualProgramme({
          programme_code: v.programme_code.trim(), title: v.title,
          parcours: v.parcours, partner_name: v.partner_name || null,
          location: v.location || null, is_active: 1,
        });
        UI.emToast('Programme manuel enregistré.','success'); loadDegraded();
      },
    }));
    $('edit-cloiso').addEventListener('click', () => {
      const c = (SETTINGS && SETTINGS.cloisonnement) || {};
      UI.emModal({
        title: 'Cloisonnement de consultation',
        fields: [
          { name:'consultation_cloisonnee', label:'État', type:'select', value: c.consultation_cloisonnee?'1':'0',
            options:[{value:'0',label:'Désactivé (tout le staff voit tout)'},{value:'1',label:'Activé'}] },
          { name:'consultation_axis', label:'Axe (champ Admission Applicant)', type:'text', value: c.consultation_axis||'status' },
          { name:'consultation_role_scopes', label:'Périmètres (JSON rôle → [valeurs])', type:'textarea', value: JSON.stringify(c.consultation_role_scopes||{}, null, 2) },
        ],
        submitLabel: 'Enregistrer',
        onSubmit: async v => {
          let scopes;
          try { scopes = JSON.parse(v.consultation_role_scopes || '{}'); }
          catch(_) { throw { code:'JSON', message:'Périmètres : JSON invalide.' }; }
          await API.updateAdminSettings({
            consultation_cloisonnee: v.consultation_cloisonnee==='1'?1:0,
            consultation_axis: v.consultation_axis,
            consultation_role_scopes: scopes,
          }, null);
          UI.emToast('Cloisonnement enregistré.','success'); loadSettings();
        },
      });
    });
    $('edit-reten').addEventListener('click', () => {
      const r = (SETTINGS && SETTINGS.retention) || {};
      UI.emModal({
        title: 'Politique de rétention (jours)',
        fields: Object.keys(r).map(k => ({ name:k, label:k, type:'number', value:r[k] })),
        submitLabel: 'Enregistrer',
        onSubmit: async v => {
          const ret = {}; Object.keys(r).forEach(k => { ret[k] = Number(v[k]); });
          await API.updateAdminSettings(null, ret);
          UI.emToast('Rétention enregistrée.','success'); loadSettings();
        },
      });
    });
  }

  window.onEmelaRole = function(role){
    if (role !== 'sm') { window.location.href = window.EmelaShell.ROLE_HOME[role] || '/connexion'; return; }
    bind(); loadDiag(); loadSettings(); loadDegraded();
  };
})();
</script>
</Layout>
