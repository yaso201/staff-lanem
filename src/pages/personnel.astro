---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Personnel — Super-admin" role="sm" page="personnel">
<style is:global>
  body { background: var(--surface-canvas); }
  .card { background: var(--surface-paper); border: 1px solid var(--border-default); border-radius: var(--radius-lg); overflow: hidden; }
  .card-head { display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); padding: var(--space-5) var(--space-7); border-bottom: 1px solid var(--border-subtle); }
  .card-title { font-size: var(--text-base); font-weight: 600; }
  .staff-row td { padding: var(--space-5) var(--space-7); vertical-align: middle; }
  .staff-nm { font-weight: 600; }
  .staff-mail { font-size: var(--text-xs); color: var(--text-tertiary); margin-top: 2px; }
  .row-actions { display: flex; gap: var(--space-3); justify-content: flex-end; flex-wrap: wrap; }
  .row.off { opacity: 0.55; }
</style>

<header class="app-top">
  <div class="app-top-inner">
    <div class="brand"><img src="/lanem-logo.webp" alt="LaNEM" style="height:36px;width:auto;display:block"></div>
    <nav class="nav">
      <a data-roles="admin" href="/espace-administratif"><svg class="ico-sm"><use href="#i-tray"/></svg>Espace de traitement</a>
      <a data-roles="resp" href="/cockpit-responsable"><svg class="ico-sm"><use href="#i-gauge"/></svg>Cockpit</a>
      <a data-roles="dir" href="/tableau-direction"><svg class="ico-sm"><use href="#i-chart"/></svg>Tableau de bord</a>
      <a href="/liste-dossiers"><svg class="ico-sm"><use href="#i-folders"/></svg>Dossiers</a>
      <a data-roles="dir" href="/gestion-sessions"><svg class="ico-sm"><use href="#i-coins"/></svg>Sessions &amp; frais</a>
      <a data-roles="sm" href="/personnel" class="is-active"><svg class="ico-sm"><use href="#i-id"/></svg>Personnel</a>
      <a data-roles="sm" href="/exploitation"><svg class="ico-sm"><use href="#i-id"/></svg>Exploitation</a>
      <a data-roles="sm" href="/reglages"><svg class="ico-sm"><use href="#i-id"/></svg>Réglages</a>
    </nav>
    <div class="app-user">
      <div class="meta"><div class="nm">—</div><div class="rl">—</div></div>
      <div class="av">—</div>
    </div>
  </div>
</header>

<main class="page">
  <div class="page-head">
    <div>
      <h1 class="page-title">Comptes du personnel</h1>
      <p class="page-sub"><b>Super-admin (SM).</b> Création de comptes, changement de rôle, réinitialisation de mot de passe (lien envoyé par e-mail) et suspension. Rôles assignables : Administratif, Responsable, Direction, Finance. Les comptes privilégiés (SM/Administrator) se gèrent au Desk/OPS.</p>
    </div>
    <button type="button" class="em-btn em-btn--primary" id="btn-create"><svg class="ico-sm"><use href="#i-plus"/></svg>Nouveau compte</button>
  </div>

  <div class="card">
    <div class="card-head"><span class="card-title">Personnel admission</span><span class="t-caption" id="staff-count">—</span></div>
    <div class="em-table-wrap" style="border:0;border-radius:0">
      <table class="em-table">
        <thead><tr><th>Personne</th><th>Rôle(s)</th><th>Statut</th><th>Dernière connexion</th><th style="text-align:right">Actions</th></tr></thead>
        <tbody id="staff-rows"><tr><td colspan="5" class="t-muted" style="padding:var(--space-6)">Chargement…</td></tr></tbody>
      </table>
    </div>
  </div>
</main>

<script is:inline>
/* LOT A (SM BACK-OFFICE) — comptes & identité staff. Le SERVEUR garde (Admission SM) ;
   le front ne fait que refléter. Aucun mot de passe en clair : le reset envoie un lien natif. */
(function(){
  const API = window.EmelaAPI, UI = window.EmelaUI, esc = UI.esc;
  const ROLE_OPTS = [
    { value: 'Admission Administratif', label: 'Administratif' },
    { value: 'Admission Responsable', label: 'Responsable' },
    { value: 'Admission Direction', label: 'Direction' },
    { value: 'Admission Finance', label: 'Finance' },
  ];
  const ROLE_LABEL = Object.fromEntries(ROLE_OPTS.map(o => [o.value, o.label]));

  function shortRoles(roles){
    return (roles||[]).map(r => ROLE_LABEL[r] || r).join(', ') || '—';
  }

  async function render(){
    try {
      const data = await API.listStaff();
      const staff = (data && data.staff) || [];
      document.getElementById('staff-count').textContent = staff.length + ' compte(s)';
      document.getElementById('staff-rows').innerHTML = staff.map(s =>
        '<tr class="staff-row'+(s.enabled?'':' off')+'">'+
        '<td><div class="staff-nm">'+esc(s.full_name)+'</div><div class="staff-mail">'+esc(s.email)+'</div></td>'+
        '<td>'+esc(shortRoles(s.roles))+'</td>'+
        '<td><span class="em-badge em-badge--'+(s.enabled?'success':'neutral')+' em-badge--sm"><span class="em-badge-dot"></span>'+(s.enabled?'Actif':'Suspendu')+'</span></td>'+
        '<td>'+esc(s.last_login ? API.fmtDate(s.last_login) : 'Jamais')+'</td>'+
        '<td><div class="row-actions">'+
          '<button type="button" class="em-btn em-btn--secondary em-btn--sm" data-act="role" data-mail="'+esc(s.email)+'">Rôle…</button>'+
          '<button type="button" class="em-btn em-btn--secondary em-btn--sm" data-act="reset" data-mail="'+esc(s.email)+'">Reset MDP…</button>'+
          '<button type="button" class="em-btn em-btn--'+(s.enabled?'secondary':'primary')+' em-btn--sm" data-act="toggle" data-mail="'+esc(s.email)+'" data-enabled="'+(s.enabled?1:0)+'">'+(s.enabled?'Suspendre…':'Réactiver')+'</button>'+
        '</div></td></tr>'
      ).join('') || '<tr><td colspan="5" class="t-muted" style="padding:var(--space-6)">Aucun compte.</td></tr>';
    } catch(e){
      if(e.code!=='AUTH') UI.emToast(e.message,'error');
    }
  }

  function createModal(){
    UI.emModal({
      title: 'Nouveau compte staff',
      lead: "Une invitation (lien de définition de mot de passe) est envoyée à l'adresse indiquée.",
      fields: [
        { name: 'full_name', label: 'Nom complet', type: 'text', required: true },
        { name: 'email', label: 'Adresse e-mail', type: 'text', required: true },
        { name: 'role', label: 'Rôle', type: 'select', required: true, options: ROLE_OPTS },
      ],
      submitLabel: 'Créer le compte',
      onSubmit: async v => {
        await API.createStaff(v.full_name, v.email, v.role);
        UI.emToast('Compte créé — invitation envoyée.','success');
        render();
      },
    });
  }

  function roleModal(email){
    UI.emModal({
      title: 'Changer le rôle',
      lead: email + '\nLe nouveau rôle remplace le rôle admission actuel.',
      fields: [{ name: 'role', label: 'Rôle', type: 'select', required: true, options: ROLE_OPTS }],
      submitLabel: 'Appliquer',
      onSubmit: async v => { await API.setStaffRole(email, v.role); UI.emToast('Rôle mis à jour.','success'); render(); },
    });
  }

  function resetModal(email){
    UI.emModal({
      title: 'Réinitialiser le mot de passe',
      lead: email + "\nUn lien de réinitialisation est envoyé par e-mail. Aucun mot de passe n'est affiché.",
      fields: [{ name: 'motif', label: 'Motif', type: 'text', required: true }],
      submitLabel: 'Envoyer le lien',
      onSubmit: async v => { await API.resetStaffPassword(email, v.motif); UI.emToast('Lien de réinitialisation envoyé.','success'); },
    });
  }

  function toggleAction(email, enabled){
    if (enabled) {
      UI.emModal({
        title: 'Suspendre le compte',
        lead: email + '\nLe compte ne pourra plus se connecter (sessions actives fermées).',
        fields: [{ name: 'motif', label: 'Motif de suspension', type: 'text', required: true }],
        submitLabel: 'Suspendre',
        onSubmit: async v => { await API.setStaffEnabled(email, false, v.motif); UI.emToast('Compte suspendu.','success'); render(); },
      });
    } else {
      API.setStaffEnabled(email, true).then(() => { UI.emToast('Compte réactivé.','success'); render(); })
        .catch(e => { if(e.code!=='AUTH') UI.emToast(e.message,'error'); });
    }
  }

  document.getElementById('btn-create').addEventListener('click', createModal);
  document.getElementById('staff-rows').addEventListener('click', e => {
    const btn = e.target.closest('[data-act]'); if(!btn) return;
    const email = btn.dataset.mail;
    if (btn.dataset.act === 'role') roleModal(email);
    else if (btn.dataset.act === 'reset') resetModal(email);
    else if (btn.dataset.act === 'toggle') toggleAction(email, btn.dataset.enabled === '1');
  });

  window.onEmelaRole = function(role){
    // Garde UX : page réservée au SM (le serveur refuse de toute façon les endpoints).
    if (role !== 'sm') { window.location.href = window.EmelaShell.ROLE_HOME[role] || '/connexion'; return; }
    render();
  };
})();
</script>
</Layout>
