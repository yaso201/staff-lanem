<!-- Barre supérieure -->
<header class="app-top">
  <div class="app-top-inner">
    <div class="brand">LaNEM<span>.</span></div>
    <nav class="nav">
      <a data-roles="admin" href="/espace-administratif" class="is-active"><svg class="ico-sm"><use href="#i-tray"/></svg>Espace de traitement</a>
      <a data-roles="resp" href="/cockpit-responsable"><svg class="ico-sm"><use href="#i-gauge"/></svg>Cockpit</a>
      <a data-roles="dir" href="/tableau-direction"><svg class="ico-sm"><use href="#i-chart"/></svg>Tableau de bord</a>
      <a href="/liste-dossiers"><svg class="ico-sm"><use href="#i-folders"/></svg>Dossiers</a>
      <a data-roles="dir" href="/gestion-sessions"><svg class="ico-sm"><use href="#i-coins"/></svg>Sessions &amp; frais</a>
      <a data-roles="sm" href="/personnel">Personnel</a>
      <a data-roles="sm" href="/exploitation">Exploitation</a>
      <a data-roles="sm" href="/reglages">Réglages</a>
    </nav>
    <div class="app-user">
      <div class="meta"><div class="nm">Estelle Gbaguidi</div><div class="rl">Agent d'admission</div></div>
      <div class="av">EG</div>
    </div>
  </div>
</header>

<main class="page">
  <div class="greet">
    <h1 id="greet">Bonjour</h1>
    <p id="greet-sub">Vos files de travail de traitement (pièces, paiements, notes).</p>
  </div>

  <div class="em-alert em-alert--warning" id="pay-alert" style="margin-bottom: var(--space-8)" hidden>
    <span class="em-alert-icon"><svg class="ico-lg"><use href="#i-warning"/></svg></span>
    <div class="em-alert-body">
      <div class="em-alert-title" id="pay-alert-title"></div>
      <div class="em-alert-text">Paiements espèces/banque déclarés par les candidats, à rapprocher et confirmer (justificatif obligatoire).</div>
      <div class="em-alert-actions">
        <a class="em-btn em-btn--primary em-btn--sm" href="/liste-dossiers?preset=sop"><svg class="ico-sm"><use href="#i-wallet"/></svg>Confirmer les paiements</a>
      </div>
    </div>
  </div>

  <p class="sec-label">Mes files de travail</p>
  <div class="queues">
    <a class="queue is-key" href="/liste-dossiers?preset=sop">
      <div class="queue-top"><span class="queue-ic warn"><svg class="ico"><use href="#i-wallet"/></svg></span><svg class="queue-go"><use href="#i-caretright"/></svg></div>
      <div class="queue-val" id="q-sop">—</div>
      <div class="queue-lab">Paiements à confirmer</div>
      <div class="queue-sub">Espèces &amp; virements déclarés</div>
    </a>
    <a class="queue is-key" href="/liste-dossiers?preset=sou">
      <div class="queue-top"><span class="queue-ic"><svg class="ico"><use href="#i-file"/></svg></span><svg class="queue-go"><use href="#i-caretright"/></svg></div>
      <div class="queue-val" id="q-sou">—</div>
      <div class="queue-lab">À mettre en étude</div>
      <div class="queue-sub">Dossiers soumis (SOU)</div>
    </a>
    <a class="queue" href="/liste-dossiers?preset=notes">
      <div class="queue-top"><span class="queue-ic"><svg class="ico"><use href="#i-medal"/></svg></span><svg class="queue-go"><use href="#i-caretright"/></svg></div>
      <div class="queue-val" id="q-notes">—</div>
      <div class="queue-lab">Notes à saisir</div>
      <div class="queue-sub">Résultats du concours Prépa</div>
    </a>
    <a class="queue" href="/liste-dossiers">
      <div class="queue-top"><span class="queue-ic"><svg class="ico"><use href="#i-folders"/></svg></span><svg class="queue-go"><use href="#i-caretright"/></svg></div>
      <div class="queue-val" id="q-all">—</div>
      <div class="queue-lab">Tous les dossiers</div>
      <div class="queue-sub">Toutes sessions</div>
    </a>
  </div>

  <div class="cols">
    <div class="card">
      <div class="card-head">
        <span class="card-title">À traiter en priorité</span>
        <a class="card-link" href="/liste-dossiers?preset=sop">Tout voir <svg class="ico-sm"><use href="#i-caretright"/></svg></a>
      </div>
      <div id="prio"></div>
    </div>
    <div>
      <div class="card">
        <div class="card-head"><span class="card-title">Accès rapides</span></div>
        <div class="qa">
          <a href="/liste-dossiers?preset=sou"><span class="qa-ic"><svg class="ico"><use href="#i-file"/></svg></span><div><div class="qa-tx">Mettre des dossiers en étude</div><div class="qa-sub">Dossiers soumis complets</div></div></a>
          <a href="/liste-dossiers?preset=notes"><span class="qa-ic"><svg class="ico"><use href="#i-pencil"/></svg></span><div><div class="qa-tx">Saisir des notes de concours</div><div class="qa-sub">Résultats Prépa</div></div></a>
        </div>
      </div>
    </div>
  </div>
</main>

<script is:inline>
/* C4-FRONT — cockpit Administratif branché sur staff.list_dossiers (plus de chiffres en dur). */
(function(){
  const API = window.EmelaAPI, esc = window.EmelaUI.esc;
  window.onEmelaRole = async function(role, me){
    document.getElementById('greet').textContent = 'Bonjour ' + ((me.full_name||me.user).split(' ')[0]);
    let D;
    try { D = (await API.listDossiers()).dossiers; }
    catch(e){ if(e.code!=='AUTH') window.EmelaUI.emToast('['+e.code+'] '+e.message,'error'); return; }
    const sop = D.filter(d=>d.paiement_a_confirmer);
    const sou = D.filter(d=>d.statut==='SOU');
    const notes = D.filter(d=>d.is_prepa && d.statut==='ETU' && d.notes==='absentes');
    document.getElementById('q-sop').textContent = sop.length;
    document.getElementById('q-sou').textContent = sou.length;
    document.getElementById('q-notes').textContent = notes.length;
    document.getElementById('q-all').textContent = D.length;
    const alertBox = document.getElementById('pay-alert');
    alertBox.hidden = !sop.length;
    document.getElementById('pay-alert-title').textContent = sop.length + ' paiement(s) en attente de confirmation';
    const prio = [...sop, ...sou, ...notes].slice(0,5);
    document.getElementById('prio').innerHTML = prio.length ? prio.map(d=>{
      const init=(d.nom||'?').split(/\s+/).map(w=>w[0]).slice(0,2).join('').toUpperCase();
      const task = d.paiement_a_confirmer?'<span class="pq-task pay"><svg class="ico-sm"><use href="#i-wallet"/></svg>Paiement</span>'
        : d.statut==='SOU'?'<span class="pq-task doc"><svg class="ico-sm"><use href="#i-file"/></svg>À mettre en étude</span>'
        : '<span class="pq-task note"><svg class="ico-sm"><use href="#i-medal"/></svg>Notes</span>';
      return '<a class="pq-row" href="/dossier?c='+encodeURIComponent(d.dossier_id)+'"><span class="pq-av">'+esc(init)+'</span>'+
        '<div class="pq-main"><div class="pq-nm">'+esc(d.nom)+'</div><div class="pq-meta">'+esc(d.programme.label||'')+' · '+esc(d.dossier_id)+'</div></div>'+
        '<div class="pq-side">'+task+'</div></a>';
    }).join('') : '<p class="t-muted" style="padding:var(--space-6)">Rien à traiter — tout est à jour.</p>';
  };
})();
</script>


</Layout>
