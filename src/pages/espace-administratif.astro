---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Espace de traitement Administratif — Front management" role="admin" page="espace">
<style is:global>

  body { background: var(--surface-canvas); }

  .greet { margin-bottom: var(--space-7); }
  .greet h1 { font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 700; letter-spacing: -0.02em; }
  .greet p { font-size: var(--text-sm); color: var(--text-secondary); margin-top: var(--space-3); }
  .greet p b { color: var(--text-primary); font-weight: 600; }

  .sec-label { font-size: var(--text-2xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-tertiary); margin: 0 0 var(--space-4); }

  .queues { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-4); margin-bottom: var(--space-9); }
  @media (max-width: 980px){ .queues { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px){ .queues { grid-template-columns: 1fr; } }
  .queue { display: flex; flex-direction: column; gap: var(--space-3); padding: var(--space-6); background: var(--surface-paper); border: 1px solid var(--border-default); border-radius: var(--radius-lg); text-decoration: none; color: inherit; transition: border-color var(--duration-fast) var(--ease-out), box-shadow var(--duration-fast) var(--ease-out); }
  .queue:hover { border-color: var(--ink-600); box-shadow: var(--shadow-sm); }
  .queue-top { display: flex; align-items: center; justify-content: space-between; }
  .queue-ic { width: 36px; height: 36px; border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; background: var(--ink-50); color: var(--ink-700); }
  .queue-ic.warn { background: var(--warning-50); color: var(--warning-700); }
  .queue-go { color: var(--sand-300); width: 18px; height: 18px; }
  .queue:hover .queue-go { color: var(--ink-600); }
  .queue-val { font-family: var(--font-display); font-size: 34px; font-weight: 700; letter-spacing: -0.02em; line-height: 1; color: var(--text-primary); font-variant-numeric: tabular-nums; }
  .queue-lab { font-size: var(--text-sm); font-weight: 600; color: var(--text-primary); }
  .queue-sub { font-size: var(--text-xs); color: var(--text-tertiary); }
  .queue.is-key { background: linear-gradient(160deg, var(--ink-900), var(--ink-800)); border: 0; color: #fff; }
  .queue.is-key .queue-ic { background: rgba(255,255,255,0.14); color: #fff; }
  .queue.is-key .queue-val, .queue.is-key .queue-lab { color: #fff; }
  .queue.is-key .queue-sub { color: rgba(255,255,255,0.7); }
  .queue.is-key .queue-go { color: rgba(255,255,255,0.6); }

  .cols { display: grid; grid-template-columns: 1.5fr 1fr; gap: var(--space-5); align-items: start; }
  @media (max-width: 920px){ .cols { grid-template-columns: 1fr; } }
  .card { background: var(--surface-paper); border: 1px solid var(--border-default); border-radius: var(--radius-lg); overflow: hidden; }
  .card-head { display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); padding: var(--space-5) var(--space-6); border-bottom: 1px solid var(--border-subtle); }
  .card-title { font-size: var(--text-base); font-weight: 600; }
  .card-link { font-size: var(--text-sm); font-weight: 600; color: var(--ink-700); text-decoration: none; display: inline-flex; align-items: center; gap: 4px; }
  .card-link:hover { color: var(--ink-900); }

  .pq-row { display: flex; align-items: center; gap: var(--space-4); padding: var(--space-4) var(--space-6); border-top: 1px solid var(--border-subtle); cursor: pointer; text-decoration: none; color: inherit; transition: background var(--duration-fast) var(--ease-out); }
  .pq-row:hover { background: var(--sand-25); }
  .pq-av { width: 34px; height: 34px; border-radius: 50%; background: var(--ink-100); color: var(--ink-800); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 12px; flex-shrink: 0; }
  .pq-main { flex: 1; min-width: 0; }
  .pq-nm { font-size: var(--text-sm); font-weight: 600; color: var(--text-primary); }
  .pq-meta { font-size: var(--text-xs); color: var(--text-tertiary); margin-top: 1px; }
  .pq-side { display: flex; align-items: center; gap: var(--space-4); flex-shrink: 0; }
  .pq-task { display: inline-flex; align-items: center; gap: var(--space-2); font-size: var(--text-xs); font-weight: 600; padding: 3px 9px; border-radius: var(--radius-full); white-space: nowrap; }
  .pq-task.doc { background: var(--ink-50); color: var(--ink-700); }
  .pq-task.pay { background: var(--warning-50); color: var(--warning-700); }
  .pq-task.note { background: var(--accent-50); color: var(--accent-700); }

  .qa { display: flex; flex-direction: column; gap: var(--space-3); padding: var(--space-5); }
  .qa a, .qa button { width: 100%; display: flex; align-items: center; gap: var(--space-4); padding: var(--space-4) var(--space-5); border: 1px solid var(--border-default); border-radius: var(--radius-md); text-decoration: none; color: inherit; transition: border-color var(--duration-fast) var(--ease-out); background: var(--surface-paper); cursor: pointer; text-align: left; }
  .qa a:hover, .qa button:hover { border-color: var(--ink-600); }
  .qa-ic { width: 34px; height: 34px; border-radius: var(--radius-sm); background: var(--ink-50); color: var(--ink-700); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .qa-tx { font-size: var(--text-sm); font-weight: 600; }
  .qa-sub { font-size: var(--text-xs); color: var(--text-tertiary); margin-top: 1px; }

</style>


