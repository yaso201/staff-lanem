---
import BareLayout from '../layouts/BareLayout.astro';
---
<BareLayout title="Page introuvable — LaNEM">
<style is:global>
  body { background: var(--surface-canvas); }
  .wrap { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: var(--space-9); }
  .auth-card { width: 100%; max-width: 440px; }
  .auth-card .em-card-body { text-align: center; }
  .logo { display: block; height: 44px; width: auto; margin: 0 auto var(--space-8); }
  .code { font-family: var(--font-display); font-size: var(--text-4xl); font-weight: 700; letter-spacing: -0.03em; color: var(--ink-900); line-height: 1; }
  .h { font-family: var(--font-display); font-size: var(--text-xl); font-weight: 700; margin-top: var(--space-5); color: var(--text-primary); }
  .sub { font-size: var(--text-sm); color: var(--text-secondary); margin-top: var(--space-4); margin-bottom: var(--space-8); line-height: 1.6; }
</style>
<main class="wrap">
  <div class="em-card auth-card">
    <div class="em-card-body">
      <img class="logo" src="/lanem-logo.webp" alt="LaNEM" />
      <div class="code">404</div>
      <h1 class="h">Page introuvable</h1>
      <p class="sub">La page demandée n'existe pas ou a été déplacée. Revenez à votre espace de gestion des admissions.</p>
      <a class="em-btn em-btn--primary em-btn--lg" href="/connexion">Retour à la connexion</a>
    </div>
  </div>
</main>
</BareLayout>
